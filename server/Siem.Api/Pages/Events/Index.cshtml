@page "/events"
@model Challenger.Siem.Api.Pages.Events.IndexModel
@{
    ViewData["Title"] = "Event search";
    var activeFilters = Model.ActiveFilters();
}

<div class="page-header">
    <div>
        <p class="page-kicker">Triage workspace</p>
        <h1>Event search</h1>
        <p class="muted">Search normalized Windows Event Log envelopes with visible filters, bounded pages, and fast pivots to event detail.</p>
    </div>
</div>

@if (Model.ErrorMessage is not null)
{
    <div class="alert" role="alert">@Model.ErrorMessage</div>
}

<form method="get" class="card filters filter-panel" aria-label="Event search filters">
    <div class="form-row">
        <label for="from">From (UTC)</label>
        <input id="from" name="from" type="datetime-local" value="@Model.FormatDateTimeInput(Model.Query.From)" />
    </div>
    <div class="form-row">
        <label for="to">To (UTC)</label>
        <input id="to" name="to" type="datetime-local" value="@Model.FormatDateTimeInput(Model.Query.To)" />
    </div>
    <div class="form-row">
        <label for="hostname">Hostname</label>
        <input id="hostname" name="hostname" value="@Model.Query.Hostname" autocomplete="off" />
    </div>
    <div class="form-row">
        <label for="agent_id">Agent ID</label>
        <input id="agent_id" name="agent_id" value="@Model.Query.AgentId" autocomplete="off" />
    </div>
    <div class="form-row">
        <label for="channel">Channel</label>
        <input id="channel" name="channel" value="@Model.Query.Channel" autocomplete="off" />
    </div>
    <div class="form-row">
        <label for="windows_event_id">Windows Event ID</label>
        <input id="windows_event_id" name="windows_event_id" type="number" min="0" max="65535" value="@Model.Query.WindowsEventId" />
    </div>
    <div class="form-row">
        <label for="keyword">Keyword</label>
        <input id="keyword" name="keyword" value="@Model.Query.Keyword" autocomplete="off" />
    </div>
    <div class="form-row">
        <label for="category">Category</label>
        <input id="category" name="category" value="@Model.Query.Category" autocomplete="off" />
    </div>
    <div class="form-row">
        <label for="action">Action</label>
        <input id="action" name="action" value="@Model.Query.Action" autocomplete="off" />
    </div>
    <div class="form-row">
        <label for="user_name">User</label>
        <input id="user_name" name="user_name" value="@Model.Query.UserName" autocomplete="off" />
    </div>
    <div class="form-row">
        <label for="process_image">Process image</label>
        <input id="process_image" name="process_image" value="@Model.Query.ProcessImage" autocomplete="off" />
    </div>
    <div class="form-row">
        <label for="destination_ip">Destination IP</label>
        <input id="destination_ip" name="destination_ip" value="@Model.Query.DestinationIp" autocomplete="off" />
    </div>
    <div class="form-row">
        <label for="limit">Limit</label>
        <input id="limit" name="limit" type="number" min="1" max="500" value="@Model.NormalizedLimit" />
    </div>
    <div class="actions">
        <button type="submit">Search events</button>
        <a class="button secondary" asp-page="/Events/Index">Clear</a>
        <span class="muted">Range filters are interpreted as UTC; event rows show host time when reported.</span>
    </div>
</form>

<section class="table-card" aria-labelledby="event-results-title">
    <div class="table-title">
        <div>
            <h2 id="event-results-title">Event results</h2>
            <p class="muted">Showing @Model.FirstResultNumber-@Model.LastResultNumber on page @Model.PageNumber with a @Model.NormalizedLimit-event limit.</p>
        </div>
        <span class="badge @(Model.Events.Count == 0 ? "warning" : "ok")">@Model.Events.Count rendered</span>
    </div>
    <div class="query-summary" aria-label="Active event filters">
        @if (activeFilters.Count == 0)
        {
            <span class="muted">No filters active. Results are newest first and capped by the visible limit.</span>
        }
        else
        {
            <div class="query-pills">
                @foreach (var filter in activeFilters)
                {
                    <span class="pill">@filter</span>
                }
            </div>
        }
    </div>
    @if (Model.Events.Count == 0)
    {
        <div class="empty">No events match the current filters.</div>
    }
    else
    {
        <div class="table-scroll">
            <table>
                <thead>
                    <tr>
                        <th>Event time</th>
                        <th>Host / Agent</th>
                        <th>Source</th>
                        <th>Event ID</th>
                        <th>Category</th>
                        <th>Action</th>
                        <th>Severity</th>
                        <th>Message</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Events)
                    {
                        <tr>
                            <td>
                                @TimeDisplay.FormatHostTime(item.EventTime, item.HostTimezone)
                                <div class="muted">@TimeDisplay.HostTimezoneLabel(item.HostTimezone)</div>
                                <div class="muted">event UTC @TimeDisplay.FormatUtc(item.EventTime)</div>
                                <div class="muted">ingested @TimeDisplay.FormatUtc(item.IngestTime, "HH:mm:ss")</div>
                            </td>
                            <td><strong>@item.Hostname</strong><div class="muted mono">@item.AgentId</div></td>
                            <td>@item.Channel<div class="muted">@item.Provider</div></td>
                            <td>@item.WindowsEventId</td>
                            <td>@(item.Normalized?.Category ?? "—")</td>
                            <td>@(item.Normalized?.Action ?? "—")</td>
                            <td><span class="badge">@item.Severity</span></td>
                            <td class="compact-cell">@Model.Preview(item.Message)</td>
                            <td>
                                <a asp-page="/Events/Detail" asp-route-agent_id="@item.AgentId" asp-route-event_id="@item.EventId">Open</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    <nav class="pagination" aria-label="Event result pages">
        <span class="muted">Page @Model.PageNumber · newest events first · raw JSON available only on detail pages.</span>
        <div class="actions">
            <a class="button secondary @(Model.HasPreviousPage ? null : "disabled")" aria-disabled="@(!Model.HasPreviousPage)" asp-page="/Events/Index" asp-route-from="@Model.Query.From" asp-route-to="@Model.Query.To" asp-route-hostname="@Model.Query.Hostname" asp-route-agent_id="@Model.Query.AgentId" asp-route-channel="@Model.Query.Channel" asp-route-windows_event_id="@Model.Query.WindowsEventId" asp-route-keyword="@Model.Query.Keyword" asp-route-category="@Model.Query.Category" asp-route-action="@Model.Query.Action" asp-route-user_name="@Model.Query.UserName" asp-route-process_image="@Model.Query.ProcessImage" asp-route-destination_ip="@Model.Query.DestinationIp" asp-route-limit="@Model.NormalizedLimit" asp-route-page="@(Model.PageNumber - 1)">Previous</a>
            <a class="button secondary @(Model.HasNextPage ? null : "disabled")" aria-disabled="@(!Model.HasNextPage)" asp-page="/Events/Index" asp-route-from="@Model.Query.From" asp-route-to="@Model.Query.To" asp-route-hostname="@Model.Query.Hostname" asp-route-agent_id="@Model.Query.AgentId" asp-route-channel="@Model.Query.Channel" asp-route-windows_event_id="@Model.Query.WindowsEventId" asp-route-keyword="@Model.Query.Keyword" asp-route-category="@Model.Query.Category" asp-route-action="@Model.Query.Action" asp-route-user_name="@Model.Query.UserName" asp-route-process_image="@Model.Query.ProcessImage" asp-route-destination_ip="@Model.Query.DestinationIp" asp-route-limit="@Model.NormalizedLimit" asp-route-page="@(Model.PageNumber + 1)">Next</a>
        </div>
    </nav>
</section>
