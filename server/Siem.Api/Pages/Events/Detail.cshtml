@page "/events/detail"
@model Challenger.Siem.Api.Pages.Events.DetailModel
@{
    ViewData["Title"] = "Event detail";
}

<div class="page-header">
    <div>
        <p class="page-kicker">Event drill-down</p>
        <h1>Event detail</h1>
        <p class="muted">Normalized fields, entities, message text, and the original raw event payload for an authenticated operator.</p>
    </div>
    <a class="button secondary" asp-page="/Events/Index">Back to search</a>
</div>

@if (Model.ErrorMessage is not null)
{
    <div class="alert" role="alert">@Model.ErrorMessage</div>
}
else if (Model.Envelope is not null)
{
    <section class="card">
        <h2>Normalized fields</h2>
        <dl class="detail-grid">
            <dt>Event ID</dt><dd>@Model.Envelope.EventId</dd>
            <dt>Agent ID</dt><dd>@Model.Envelope.AgentId</dd>
            <dt>Hostname</dt><dd>@Model.Envelope.Hostname</dd>
            <dt>Source</dt><dd>@Model.Envelope.Source</dd>
            <dt>Platform</dt><dd>@(Model.Envelope.Platform ?? "—")</dd>
            <dt>Source ID</dt><dd>@(Model.Envelope.SourceId ?? "—")</dd>
            <dt>Event code</dt><dd>@(Model.Envelope.EventCode ?? "—")</dd>
            <dt>Facility</dt><dd>@(Model.Envelope.Facility ?? "—")</dd>
            <dt>Unit</dt><dd>@(Model.Envelope.Unit ?? "—")</dd>
            <dt>Channel</dt><dd>@(Model.Envelope.Channel ?? "—")</dd>
            <dt>Provider</dt><dd>@(Model.Envelope.Provider ?? "—")</dd>
            <dt>Windows Event ID</dt><dd>@(Model.Envelope.WindowsEventId?.ToString() ?? "—")</dd>
            <dt>Record ID</dt><dd>@(Model.Envelope.RecordId?.ToString() ?? "—")</dd>
            <dt>Event host time</dt><dd>@TimeDisplay.FormatHostTime(Model.Envelope.EventTime, Model.Envelope.HostTimezone)<div class="muted">@TimeDisplay.HostTimezoneLabel(Model.Envelope.HostTimezone)</div></dd>
            <dt>Event UTC</dt><dd>@TimeDisplay.FormatUtc(Model.Envelope.EventTime)</dd>
            <dt>Ingest time</dt><dd>@TimeDisplay.FormatUtc(Model.Envelope.IngestTime)</dd>
            <dt>Host timezone</dt><dd>@TimeDisplay.HostTimezoneShortLabel(Model.Envelope.HostTimezone)</dd>
            <dt>Severity</dt><dd><span class="badge">@Model.Envelope.Severity</span></dd>
            <dt>Category</dt><dd>@(Model.Envelope.Normalized?.Category ?? "—")</dd>
            <dt>Action</dt><dd>@(Model.Envelope.Normalized?.Action ?? "—")</dd>
            <dt>Outcome</dt><dd>@(Model.Envelope.Normalized?.Outcome ?? "—")</dd>
            <dt>User</dt><dd>@(Model.Envelope.Normalized?.UserName ?? "—")</dd>
            <dt>Target user</dt><dd>@(Model.Envelope.Normalized?.TargetUserName ?? "—")</dd>
            <dt>Process</dt><dd>@(Model.Envelope.Normalized?.ProcessImage ?? "—")</dd>
            <dt>Service</dt><dd>@(Model.Envelope.Normalized?.ServiceName ?? "—")</dd>
            <dt>Task</dt><dd>@(Model.Envelope.Normalized?.TaskName ?? "—")</dd>
            <dt>Package</dt><dd>@(Model.Envelope.Normalized?.PackageName ?? "—")</dd>
            <dt>Source network</dt><dd>@(Model.Envelope.Normalized?.SourceIp ?? "—"):@(Model.Envelope.Normalized?.SourcePort ?? "—")</dd>
            <dt>Destination network</dt><dd>@(Model.Envelope.Normalized?.DestinationIp ?? "—"):@(Model.Envelope.Normalized?.DestinationPort ?? "—")</dd>
            <dt>Protocol</dt><dd>@(Model.Envelope.Normalized?.Protocol ?? "—")</dd>
        </dl>
    </section>

    <section class="card">
        <h2>Entities</h2>
        @if (Model.Envelope.Normalized?.Entities.Count > 0)
        {
            <ul>
                @foreach (var entity in Model.Envelope.Normalized.Entities)
                {
                    <li><strong>@entity.Type</strong> @entity.Value <span class="muted">@entity.Role</span></li>
                }
            </ul>
        }
        else
        {
            <p class="muted">No normalized entities were reported.</p>
        }
    </section>

    <section class="card">
        <h2>Message</h2>
        <pre class="message-box">@Model.Envelope.Message</pre>
    </section>

    <section class="card">
        <div class="page-header">
            <div>
                <h2>Raw JSON</h2>
                <p class="muted">Rendered only on the authenticated detail page; do not copy into public issues, docs, or logs.</p>
            </div>
            <button type="button" class="secondary" onclick="navigator.clipboard?.writeText(document.getElementById('raw-json').value)">Copy raw JSON</button>
        </div>
        <textarea id="raw-json" class="raw-json" readonly>@Model.RawJson</textarea>
    </section>
}
