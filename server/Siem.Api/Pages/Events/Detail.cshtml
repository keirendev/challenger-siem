@page "/events/detail"
@model Challenger.Siem.Api.Pages.Events.DetailModel
@{
    ViewData["Title"] = "Event detail";
}

<partial name="_Breadcrumbs" model='BreadcrumbsModel.Create(new BreadcrumbItem("Overview", Page: "/Index"), new BreadcrumbItem("Search", Page: "/Events/Index"), new BreadcrumbItem("Event detail", IsCurrent: true))' />

<div class="page-header">
    <div>
        <p class="page-kicker">Event drill-down</p>
        <h1>Event detail</h1>
        <p class="muted">Normalized fields, ingest/checkpoint metadata, role-redacted raw payload, and safe entity pivots.</p>
    </div>
    <a class="button secondary" asp-page="/Events/Index">Back to search</a>
</div>

@if (Model.ErrorMessage is not null)
{
    <partial name="_Notice" model='new NoticeModel("Event unavailable", Model.ErrorMessage, "error", IsAlert: true)' />
}
else if (Model.Envelope is not null)
{
    <partial name="_Notice" model='new NoticeModel("Raw payload policy", Model.RawJson == "{}" ? "Raw payload and protected fields are omitted or redacted for this role." : "Raw payload is visible to this role. Keep it out of public issues, docs, screenshots, logs, and exports unless synthetic.", "partial")' />
    <partial name="_Tabs" model='new TabsModel("Event detail sections", new[] { new TabItem("Fields", "#fields", true), new TabItem("Metadata", "#metadata"), new TabItem("Entities", "#entities"), new TabItem("Message", "#message"), new TabItem("Raw JSON", "#raw") })' />
    <section class="card" id="fields">
        <h2>Normalized fields</h2>
        <dl class="detail-grid">
            <dt>Event ID</dt><dd>@Model.Envelope.EventId</dd>
            <dt>Agent ID</dt><dd>@Model.Envelope.AgentId</dd>
            <dt>Hostname</dt><dd>@Model.Envelope.Hostname</dd>
            <dt>Source</dt><dd>@Model.Envelope.Source</dd>
            <dt>Platform</dt><dd>@(Model.Envelope.Platform ?? "—")</dd>
            <dt>Source ID</dt><dd>@(Model.Envelope.SourceId ?? "—")</dd>
            <dt>Event code</dt><dd>@(Model.Envelope.EventCode ?? "—")</dd>
            <dt>Facility</dt><dd>@(Model.Envelope.Facility ?? "—")</dd>
            <dt>Unit</dt><dd>@(Model.Envelope.Unit ?? "—")</dd>
            <dt>Channel</dt><dd>@(Model.Envelope.Channel ?? "—")</dd>
            <dt>Provider</dt><dd>@(Model.Envelope.Provider ?? "—")</dd>
            <dt>Windows Event ID</dt><dd>@(Model.Envelope.WindowsEventId?.ToString() ?? "—")</dd>
            <dt>Record ID</dt><dd>@(Model.Envelope.RecordId?.ToString() ?? "—")</dd>
            <dt>Event host time</dt><dd>@TimeDisplay.FormatHostTime(Model.Envelope.EventTime, Model.Envelope.HostTimezone)<div class="muted">@TimeDisplay.HostTimezoneLabel(Model.Envelope.HostTimezone)</div></dd>
            <dt>Event UTC</dt><dd>@TimeDisplay.FormatUtc(Model.Envelope.EventTime)</dd>
            <dt>Ingest time</dt><dd>@TimeDisplay.FormatUtc(Model.Envelope.IngestTime)</dd>
            <dt>Host timezone</dt><dd>@TimeDisplay.HostTimezoneShortLabel(Model.Envelope.HostTimezone)</dd>
            <dt>Severity</dt><dd><span class="badge">@Model.Envelope.Severity</span></dd>
            <dt>Category</dt><dd>@(Model.Envelope.Normalized?.Category ?? "—")</dd>
            <dt>Action</dt><dd>@(Model.Envelope.Normalized?.Action ?? "—")</dd>
            <dt>Outcome</dt><dd>@(Model.Envelope.Normalized?.Outcome ?? "—")</dd>
            <dt>User</dt><dd>@(Model.Envelope.Normalized?.UserName ?? "—")</dd>
            <dt>Target user</dt><dd>@(Model.Envelope.Normalized?.TargetUserName ?? "—")</dd>
            <dt>Process ID</dt><dd>@(Model.Envelope.Normalized?.ProcessId ?? Model.Envelope.Normalized?.Process?.Pid ?? "—")</dd>
            <dt>Parent process ID</dt><dd>@(Model.Envelope.Normalized?.ParentProcessId ?? Model.Envelope.Normalized?.Process?.ParentPid ?? "—")</dd>
            <dt>Process</dt><dd>@(Model.Envelope.Normalized?.ProcessImage ?? Model.Envelope.Normalized?.Process?.Executable ?? "—")</dd>
            <dt>Command line</dt><dd>@(Model.Envelope.Normalized?.ProcessCommandLine ?? Model.Envelope.Normalized?.Process?.CommandLine ?? "—")</dd>
            <dt>Service</dt><dd>@(Model.Envelope.Normalized?.ServiceName ?? "—")</dd>
            <dt>Task</dt><dd>@(Model.Envelope.Normalized?.TaskName ?? "—")</dd>
            <dt>Package</dt><dd>@(Model.Envelope.Normalized?.PackageName ?? "—")</dd>
            <dt>File</dt><dd>@(Model.Envelope.Normalized?.FilePath ?? Model.Envelope.Normalized?.File?.Path ?? "—")</dd>
            <dt>File hash</dt><dd>@(Model.Envelope.Normalized?.Hash ?? Model.Envelope.Normalized?.File?.Sha256 ?? "—")</dd>
            <dt>Registry</dt><dd>@(Model.Envelope.Normalized?.RegistryKey ?? "—")</dd>
            <dt>Source network</dt><dd>@(Model.Envelope.Normalized?.SourceIp ?? Model.Envelope.Normalized?.Network?.SourceIp ?? "—"):@(Model.Envelope.Normalized?.SourcePort ?? Model.Envelope.Normalized?.Network?.SourcePort?.ToString() ?? "—")</dd>
            <dt>Destination network</dt><dd>@(Model.Envelope.Normalized?.DestinationIp ?? Model.Envelope.Normalized?.Network?.DestinationIp ?? "—"):@(Model.Envelope.Normalized?.DestinationPort ?? Model.Envelope.Normalized?.Network?.DestinationPort?.ToString() ?? "—")</dd>
            <dt>Protocol</dt><dd>@(Model.Envelope.Normalized?.Protocol ?? Model.Envelope.Normalized?.Network?.Protocol ?? "—")</dd>
        </dl>
    </section>

    <section class="card" id="metadata">
        <h2>Ingest, checkpoint, and handling metadata</h2>
        <dl class="detail-grid">
            <dt>Checkpoint cursor</dt><dd>@(Model.Envelope.Checkpoint?.Cursor ?? "—")</dd>
            <dt>Checkpoint sequence</dt><dd>@(Model.Envelope.Checkpoint?.Sequence?.ToString() ?? "—")</dd>
            <dt>Checkpoint event time</dt><dd>@TimeDisplay.FormatUtc(Model.Envelope.Checkpoint?.EventTime)</dd>
            <dt>Dedup algorithm</dt><dd>@(Model.Envelope.Deduplication?.Algorithm ?? "legacy/server key")</dd>
            <dt>Dedup inputs</dt><dd>@(Model.Envelope.Deduplication is null ? "—" : string.Join(", ", Model.Envelope.Deduplication.Inputs))</dd>
            <dt>Raw size bytes</dt><dd>@(Model.Envelope.DataHandling?.RawSizeBytes.ToString() ?? "—")</dd>
            <dt>Redaction before queue</dt><dd>@(Model.Envelope.DataHandling?.RedactionApplied.ToString() ?? "—")</dd>
            <dt>Truncation before queue</dt><dd>@(Model.Envelope.DataHandling?.TruncationApplied.ToString() ?? "—")</dd>
        </dl>
    </section>

    <section class="card" id="entities">
        <h2>Entities and pivots</h2>
        @if (Model.Envelope.Normalized?.Entities.Count > 0)
        {
            <ul class="entity-list">
                @foreach (var entity in Model.Envelope.Normalized.Entities)
                {
                    <li><strong>@entity.Type</strong> @entity.Value <span class="muted">@entity.Role</span> <a asp-page="/Events/Index" asp-route-entity_type="@entity.Type" asp-route-entity_value="@entity.Value" asp-route-from="@Model.Envelope.EventTime.AddHours(-1).ToString("O")" asp-route-to="@Model.Envelope.EventTime.AddHours(1).ToString("O")">Pivot ±1h</a></li>
                }
            </ul>
        }
        else
        {
            <p class="muted">No normalized entities were reported or they are redacted for this role.</p>
        }
        <div class="actions">
            <a class="button secondary" asp-page="/Events/Index" asp-route-agent_id="@Model.Envelope.AgentId" asp-route-from="@Model.Envelope.EventTime.AddHours(-1).ToString("O")" asp-route-to="@Model.Envelope.EventTime.AddHours(1).ToString("O")">Host timeline ±1h</a>
            <a class="button secondary" asp-page="/Events/Index" asp-route-source_id="@Model.Envelope.SourceId" asp-route-channel="@Model.Envelope.Channel" asp-route-from="@Model.Envelope.EventTime.AddHours(-1).ToString("O")" asp-route-to="@Model.Envelope.EventTime.AddHours(1).ToString("O")">Source pivot ±1h</a>
        </div>
    </section>

    <section class="card" id="message">
        <h2>Message</h2>
        <pre class="message-box">@Model.Envelope.Message</pre>
    </section>

    <section class="card" id="raw">
        <div class="page-header">
            <div>
                <h2>Raw JSON</h2>
                <p class="muted">Admin-only full display. Non-admin roles receive an omitted/redacted object and explicit policy notice.</p>
            </div>
            @if (Model.RawJson != "{}")
            {
                <button type="button" class="secondary" data-copy-from="raw-json">Copy raw JSON</button>
            }
        </div>
        <textarea id="raw-json" class="raw-json" readonly>@Model.RawJson</textarea>
    </section>
}
