@page "/agents/detail"
@model Challenger.Siem.Api.Pages.Agents.DetailModel
@{
    ViewData["Title"] = "Host coverage";
}

<div class="page-header">
    <div>
        <p class="page-kicker">Source health</p>
        <h1>Host coverage</h1>
        <p class="muted">Coverage level, recent event validation, source health, inventory/audit-policy state, and detection prerequisites for one agent.</p>
    </div>
    <a class="button secondary" asp-page="/Agents/Index">Back to agents</a>
</div>

@if (!string.IsNullOrWhiteSpace(Model.AgentId))
{
    <section class="card filters filter-panel" aria-label="Coverage target selector">
        <div class="table-title">
            <div>
                <h2>Coverage target</h2>
                <p class="muted">Review the same host against L1 native, L2 Windows security, L3 Sysmon, or L4 role-pack expectations.</p>
            </div>
            <div class="actions">
                @foreach (var level in Model.TargetLevels)
                {
                    <a class="button @(level == Model.TargetLevel ? null : "secondary")" asp-page="/Agents/Detail" asp-route-agent_id="@Model.AgentId" asp-route-target_level="@level">@level</a>
                }
            </div>
        </div>
    </section>
}

@if (Model.ErrorMessage is not null)
{
    <div class="alert" role="alert">@Model.ErrorMessage</div>
}
else if (Model.Summary is null)
{
    <section class="card"><p>No source-health data is available for @Model.AgentId.</p></section>
}
else
{
    <section class="metrics" aria-label="Coverage metrics">
        <article class="card"><span class="metric-value">@Model.Summary.CurrentLevel</span><span class="metric-label">current coverage</span></article>
        <article class="card"><span class="metric-value">@Model.TargetLevel</span><span class="metric-label">target coverage</span></article>
        <article class="card"><span class="metric-value">@Model.Summary.OverallStatus</span><span class="metric-label">coverage status</span></article>
        <article class="card"><span class="metric-value">@(Model.Coverage?.RecentEventCount.ToString() ?? "—")</span><span class="metric-label">recent events / 24h</span></article>
        <article class="card"><span class="metric-value">@(Model.Coverage is null ? "—" : $"{Model.Coverage.ReportedSourceCount}/{Model.Coverage.ExpectedSourceCount}")</span><span class="metric-label">reported / expected sources</span></article>
        <article class="card"><span class="metric-value">@Model.Summary.MissingMandatorySources</span><span class="metric-label">missing mandatory</span></article>
        <article class="card"><span class="metric-value">@Model.Summary.StaleSources</span><span class="metric-label">stale sources</span></article>
        <article class="card"><span class="metric-value">@Model.Summary.ErrorSources</span><span class="metric-label">error sources</span></article>
        <article class="card"><span class="metric-value">@(Model.Coverage?.NewAlertCount.ToString() ?? "—")</span><span class="metric-label">new alerts / 24h</span></article>
        <article class="card"><span class="metric-value">@(Model.Coverage?.ActiveGraphCount.ToString() ?? "—")</span><span class="metric-label">active graphs</span></article>
        <article class="card"><span class="metric-value">@Model.Summary.QueueDepth</span><span class="metric-label">queue depth</span></article>
    </section>

    @if (Model.Coverage?.Gaps.Count > 0)
    {
        <section class="card" aria-labelledby="coverage-gaps-title">
            <div class="table-title">
                <div>
                    <h2 id="coverage-gaps-title">Telemetry completeness gaps</h2>
                    <p class="muted">These gaps mean telemetry is not validated; they do not imply a confirmed detection miss.</p>
                </div>
            </div>
            <ul>
                @foreach (var gap in Model.Coverage.Gaps)
                {
                    <li>@gap</li>
                }
            </ul>
        </section>
    }

    <section class="table-card">
        <div class="table-title">
            <div>
                <h2>Expected source matrix</h2>
                <p class="muted">Validation shows one row per expected Windows source for the selected target, including synthetic missing rows when a source has not been reported.</p>
            </div>
        </div>
        @if (Model.Sources.Count == 0)
        {
            <div class="empty">No source-health rows have been reported by this agent.</div>
        }
        else
        {
            <div class="table-scroll">
                <table>
                    <thead>
                        <tr>
                            <th>Source</th>
                            <th>Level</th>
                            <th>Status</th>
                            <th>Required</th>
                            <th>Reported</th>
                            <th>Recent events</th>
                            <th>Last event</th>
                            <th>Config/source</th>
                            <th>Reason</th>
                            <th>Review</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var source in Model.Sources)
                        {
                            <tr>
                                <td><strong>@source.DisplayName</strong><div class="muted">@source.Channel</div></td>
                                <td>@source.CoverageLevel</td>
                                <td><span class="badge @(source.Status == "healthy" ? "ok" : source.Status == "stale" || source.Status == "missing" ? "warning" : "danger")">@source.Status</span></td>
                                <td>@(source.Required ? "yes" : "no")</td>
                                <td>@(source.Reported ? "yes" : "no")</td>
                                <td>@source.RecentEventCount</td>
                                <td>@(source.LastEventTime?.ToLocalTime().ToString("yyyy-MM-dd HH:mm") ?? "—")</td>
                                <td>
                                    <span>@(string.IsNullOrWhiteSpace(source.SourceVersion) ? "—" : source.SourceVersion)</span>
                                    @if (!string.IsNullOrWhiteSpace(source.ConfigHash))
                                    {
                                        var shortHash = source.ConfigHash.Length > 12 ? source.ConfigHash[..12] : source.ConfigHash;
                                        <div class="muted mono">hash @shortHash</div>
                                    }
                                    @if (source.Details.TryGetValue("source_pack", out var sourcePack))
                                    {
                                        <div class="muted">@sourcePack</div>
                                    }
                                </td>
                                <td>@source.Reason</td>
                                <td><a href="@source.EventSearchUrl">events</a></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>

    @if (Model.Coverage is not null)
    {
        <section class="table-card" aria-labelledby="inventory-coverage-title">
            <div class="table-title">
                <div>
                    <h2 id="inventory-coverage-title">Inventory and audit-policy snapshots</h2>
                    <p class="muted">Missing or stale snapshots are explicit completeness gaps for host context and audit-policy prerequisites.</p>
                </div>
            </div>
            <div class="table-scroll">
                <table>
                    <thead><tr><th>Snapshot</th><th>Status</th><th>Latest</th><th>Items</th><th>Reason</th><th>Review</th></tr></thead>
                    <tbody>
                    @foreach (var snapshot in Model.Coverage.Inventory)
                    {
                        <tr>
                            <td>@snapshot.SnapshotType</td>
                            <td><span class="badge @(snapshot.Status == "healthy" ? "ok" : snapshot.Status == "missing" || snapshot.Status == "stale" ? "warning" : "danger")">@snapshot.Status</span></td>
                            <td>@(snapshot.LatestCollectedAt?.ToLocalTime().ToString("yyyy-MM-dd HH:mm") ?? "—")</td>
                            <td>@snapshot.ItemCount</td>
                            <td>@snapshot.Reason</td>
                            <td>
                                @if (snapshot.Url.StartsWith("/api/", StringComparison.OrdinalIgnoreCase))
                                {
                                    <span class="muted">API</span>
                                }
                                else
                                {
                                    <a href="@snapshot.Url">open</a>
                                }
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </section>

        <section class="table-card" aria-labelledby="detection-prereq-title">
            <div class="table-title">
                <div>
                    <h2 id="detection-prereq-title">Detection prerequisite status</h2>
                    <p class="muted">Each built-in Windows detection rule is compared with source health, recent event presence, inventory, and audit-policy prerequisites.</p>
                </div>
            </div>
            <div class="table-scroll">
                <table>
                    <thead><tr><th>Rule</th><th>Status</th><th>Required sources</th><th>Recent source events</th><th>Missing/stale</th><th>Reason</th></tr></thead>
                    <tbody>
                    @foreach (var rule in Model.Coverage.DetectionPrerequisites)
                    {
                        <tr>
                            <td><strong>@rule.Name</strong><div class="muted mono">@rule.RuleId · @rule.Severity</div></td>
                            <td><span class="badge @(rule.Status == "satisfied" ? "ok" : rule.Status == "unknown" || rule.Status == "partially_satisfied" ? "warning" : "danger")">@rule.Status</span></td>
                            <td>@string.Join(", ", rule.RequiredSources)</td>
                            <td>@(rule.RecentEventSources.Count == 0 ? "—" : string.Join(", ", rule.RecentEventSources))</td>
                            <td>@string.Join(", ", rule.MissingSources.Concat(rule.StaleSources).Distinct())</td>
                            <td>@rule.Reason</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </section>
    }
}
