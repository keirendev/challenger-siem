@page "/agents/detail"
@model Challenger.Siem.Api.Pages.Agents.DetailModel
@{
    ViewData["Title"] = "Host coverage";
}

<partial name="_Breadcrumbs" model='BreadcrumbsModel.Create(new BreadcrumbItem("Overview", Page: "/Index"), new BreadcrumbItem("Assets", Page: "/Agents/Index"), new BreadcrumbItem("Host coverage", IsCurrent: true))' />

<div class="page-header">
    <div>
        <p class="page-kicker">Source health</p>
        <h1>Host coverage</h1>
        <p class="muted">Coverage level, recent event validation, source health, inventory/audit-policy state, and detection prerequisites for one agent.</p>
    </div>
    <a class="button secondary" asp-page="/Agents/Index">Back to agents</a>
</div>

@if (!string.IsNullOrWhiteSpace(Model.AgentId))
{
    <section class="card filters filter-panel" aria-label="Coverage target selector">
        <div class="table-title">
            <div>
                <h2>Coverage target</h2>
                <p class="muted">Review the host against its platform catalog. Linux supports L1, opt-in L2, explicit-opt-in L3 sources, and strict approval-gated L4; the current level advances only when healthy applicable evidence exists at that level. L4 requires exact healthy L1–L3 prerequisites, both mandatory L4 posture/performance sources, resolved role applicability, and every applicable role pack enabled, fresh, and healthy. Coverage exceptions never satisfy this strict L4 gate.</p>
            </div>
            <div class="actions">
                @foreach (var level in Model.TargetLevels)
                {
                    <a class="button @(level == Model.TargetLevel ? null : "secondary")" asp-page="/Agents/Detail" asp-route-agent_id="@Model.AgentId" asp-route-target_level="@level">@level</a>
                }
            </div>
        </div>
    </section>
}

@if (Model.ErrorMessage is not null)
{
    <partial name="_Notice" model='new NoticeModel("Coverage unavailable", Model.ErrorMessage, "error", IsAlert: true)' />
}
else if (Model.Summary is null)
{
    <partial name="_Notice" model='new NoticeModel("No source health", $"No source-health data is available for {Model.AgentId}. This is an unknown telemetry state, not proof of health.", "empty")' />
}
else
{
    <partial name="_Tabs" model='new TabsModel("Asset coverage sections", new[] { new TabItem("Summary", "#summary", true), new TabItem("Sources", "#sources"), new TabItem("Inventory", "#inventory"), new TabItem("Detections", "#detections"), new TabItem("Timeline", "#", IsDisabled: true, Description: "Timeline is planned.") })' />
    <section class="metrics" id="summary" aria-label="Coverage metrics">
        <article class="card"><span class="metric-value">@Model.Summary.CurrentLevel</span><span class="metric-label">current coverage</span></article>
        <article class="card"><span class="metric-value">@Model.TargetLevel</span><span class="metric-label">target coverage</span></article>
        <article class="card"><span class="metric-value">@Model.Summary.OverallStatus</span><span class="metric-label">coverage status</span></article>
        <article class="card"><span class="metric-value">@(Model.Coverage?.RecentEventCount.ToString() ?? "—")</span><span class="metric-label">recent events / 24h</span></article>
        <article class="card"><span class="metric-value">@(Model.Coverage is null ? "—" : $"{Model.Coverage.ReportedSourceCount}/{Model.Coverage.ExpectedSourceCount}")</span><span class="metric-label">reported / expected sources</span></article>
        <article class="card"><span class="metric-value">@Model.Summary.MissingMandatorySources</span><span class="metric-label">missing mandatory</span></article>
        <article class="card"><span class="metric-value">@Model.Summary.StaleSources</span><span class="metric-label">stale sources</span></article>
        <article class="card"><span class="metric-value">@Model.Summary.ErrorSources</span><span class="metric-label">error sources</span></article>
        <article class="card"><span class="metric-value">@Model.Summary.DegradedSources</span><span class="metric-label">degraded sources</span></article>
        <article class="card"><span class="metric-value">@Model.Summary.PermissionDeniedSources</span><span class="metric-label">permission denied</span></article>
        <article class="card"><span class="metric-value">@Model.Summary.UnsupportedSources</span><span class="metric-label">unsupported sources</span></article>
        <article class="card"><span class="metric-value">@(Model.Coverage?.NewAlertCount.ToString() ?? "—")</span><span class="metric-label">new alerts / 24h</span></article>
        <article class="card"><span class="metric-value">@(Model.Coverage?.ActiveGraphCount.ToString() ?? "—")</span><span class="metric-label">active graphs</span></article>
        <article class="card"><span class="metric-value">@Model.Summary.QueueDepth</span><span class="metric-label">queue depth</span></article>
        <article class="card"><span class="metric-value">@TimeDisplay.HostTimezoneShortLabel(Model.Coverage?.HostTimezone ?? Model.Summary.HostTimezone)</span><span class="metric-label">host timezone</span></article>
    </section>

    <section class="card" aria-labelledby="health-state-title">
        <div class="table-title flush-title">
            <div>
                <h2 id="health-state-title">Health state interpretation and guidance</h2>
                <p class="muted">These states describe visibility evidence only. Guidance is non-mutating: no button here changes host audit, firewall, authentication, kernel, service, package, or security policy.</p>
            </div>
        </div>
        <div class="state-grid">
            @foreach (var state in new[] { "missing", "unsupported", "not_applicable", "excepted", "disabled", "permission_denied", "stale", "throttled", "gap", "error" })
            {
                var count = state switch
                {
                    "missing" => Model.Summary.MissingMandatorySources,
                    "unsupported" => Model.Summary.UnsupportedSources,
                    "not_applicable" => Model.Summary.NotApplicableSources,
                    "excepted" => Model.Summary.ExceptedSources,
                    "disabled" => Model.Sources.Count(source => source.Status == "disabled"),
                    "permission_denied" => Model.Summary.PermissionDeniedSources,
                    "stale" => Model.Summary.StaleSources,
                    "throttled" => Model.Sources.Count(source => source.TransitionState == "degraded" || (source.Details.TryGetValue("throttle_state", out var throttleState) && throttleState == "throttled")),
                    "gap" => Model.Sources.Count(source => source.GapCount.GetValueOrDefault() > 0 || source.DroppedEvents.GetValueOrDefault() > 0 || (source.Details.TryGetValue("gap_state", out var gapState) && !string.IsNullOrWhiteSpace(gapState))),
                    "error" => Model.Summary.ErrorSources,
                    _ => 0
                };
                <article class="state-chip">
                    <span class="badge @(count == 0 ? "neutral" : state is "error" or "permission_denied" ? "danger" : "warning")">@state</span>
                    <strong>@count</strong>
                    <span class="muted">@(count == 0 ? "not observed in current evidence" : "review required")</span>
                </article>
            }
        </div>
    </section>

    <section class="card" aria-labelledby="queue-resource-title">
        <div class="table-title flush-title"><div><h2 id="queue-resource-title">Agent queue, resource, retention, and capacity metrics</h2><p class="muted">Unknown means the agent or storage API did not report the measurement; observed zero is shown as 0.</p></div></div>
        <dl class="detail-grid">
            <dt>Queue depth</dt><dd>@Model.Summary.QueueMetrics?.QueueDepth</dd>
            <dt>Poison queue depth</dt><dd>@Model.Summary.QueueMetrics?.PoisonDepth</dd>
            <dt>Queue oldest age</dt><dd>@(Model.Summary.QueueMetrics?.OldestQueuedAgeSeconds?.ToString() ?? "unknown") seconds</dd>
            <dt>Queue pressure</dt><dd><span class="badge @(Model.Summary.QueueMetrics?.PressureState is "normal" ? "ok" : "warning")">@(Model.Summary.QueueMetrics?.PressureState ?? "unknown")</span></dd>
            <dt>Queue capacity</dt><dd><span class="badge @DetailModel.CapacityState(Model.Summary.QueueMetrics?.UsedPercent)">@DetailModel.CapacityState(Model.Summary.QueueMetrics?.UsedPercent)</span> @(Model.Summary.QueueMetrics?.UsedPercent?.ToString("0.###") ?? "unknown")% — @DetailModel.CapacityGuidance(DetailModel.CapacityState(Model.Summary.QueueMetrics?.UsedPercent))</dd>
            <dt>Last successful send</dt><dd>@TimeDisplay.FormatUtc(Model.Summary.QueueMetrics?.LastSuccessfulSendTime, "yyyy-MM-dd HH:mm:ss")</dd>
            <dt>Agent CPU</dt><dd>@(Model.Summary.ResourceMetrics?.CpuPercent?.ToString("0.###") ?? "unknown")%</dd>
            <dt>Agent RSS</dt><dd>@(Model.Summary.ResourceMetrics?.RssBytes?.ToString() ?? "unknown") bytes</dd>
            <dt>Managed telemetry capacity</dt><dd><span class="badge @(Model.StorageAccounting?.WarningState ?? "unknown")">@(Model.StorageAccounting?.WarningState ?? "unknown")</span> @(Model.StorageAccounting?.UsedPercent.ToString("0.###") ?? "unknown")% used of @(Model.StorageAccounting?.CapacityBytes.ToString() ?? "unknown") bytes. Thresholds: 70% warning, 85% warning, 95% critical, 100% over capacity.</dd>
            <dt>Retention lag</dt><dd>@(Model.StorageAccounting?.RetentionLagState ?? "unknown") @(Model.StorageAccounting?.RetentionLagSeconds?.ToString() ?? string.Empty)</dd>
        </dl>
    </section>

    @if (Model.Coverage?.Gaps.Count > 0)
    {
        <section class="card" aria-labelledby="coverage-gaps-title">
            <div class="table-title">
                <div>
                    <h2 id="coverage-gaps-title">Telemetry completeness gaps</h2>
                    <p class="muted">These gaps mean telemetry is not validated; they do not imply a confirmed detection miss.</p>
                </div>
            </div>
            <ul>
                @foreach (var gap in Model.Coverage.Gaps)
                {
                    <li>@gap</li>
                }
            </ul>
        </section>
    }

    @if (Model.TargetLevel == WindowsCoverageLevel.L4 && Model.Summary.CurrentLevel < WindowsCoverageLevel.L4)
    {
        <partial name="_Notice" model='new NoticeModel("L4 evidence incomplete", "This host remains at its highest fully evidenced lower level. Unknown role applicability, an exception, a stale observation, warm-up, or unhealthy mandatory/applicable source prevents L4; quiet successful polling does not require a synthetic security event.", "warning")' />
    }

    <section class="table-card" id="sources">
        <div class="table-title">
            <div>
                <h2>Expected source matrix</h2>
                <p class="muted">Validation shows one row per expected platform source, including calculated missing rows and explicit requirement, applicability, and exception state.</p>
            </div>
        </div>
        @if (Model.Sources.Count == 0)
        {
            <div class="empty">No source-health rows have been reported by this agent.</div>
        }
        else
        {
            <div class="table-scroll">
                <table>
                    <caption>Expected source matrix with explicit status, requirement, applicability, recency, and review pivots</caption>
                    <thead>
                        <tr>
                            <th>Source</th>
                            <th>Level</th>
                            <th>Status</th>
                            <th>Requirement</th>
                            <th>Reported</th>
                            <th>Recent events</th>
                            <th>Last event</th>
                            <th>Rate/lag/checkpoint</th>
                            <th>Config/source</th>
                            <th>Guidance</th>
                            <th>Review</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var source in Model.Sources)
                        {
                            <tr>
                                <td>
                                    <strong>@source.DisplayName</strong>
                                    <div class="muted mono">@(string.IsNullOrWhiteSpace(source.Channel) ? source.SourceId : source.Channel)</div>
                                </td>
                                <td>@source.CoverageLevel</td>
                                <td><span class="badge @(source.Status is "healthy" or "not_applicable" or "excepted" ? "ok" : source.Status is "stale" or "missing" or "degraded" or "disabled" ? "warning" : "danger")">@source.Status</span></td>
                                <td>
                                    @(source.Requirement ?? (source.Required ? "mandatory" : "optional"))
                                    @if (!string.IsNullOrWhiteSpace(source.Applicability))
                                    {
                                        <div class="muted">@source.Applicability</div>
                                    }
                                    @if (source.ApplicableRoles?.Count > 0)
                                    {
                                        <div class="muted">roles: @string.Join(", ", source.ApplicableRoles)</div>
                                    }
                                </td>
                                <td>@(source.Reported ? "yes" : "no")</td>
                                <td>@source.RecentEventCount</td>
                                <td>
                                    @TimeDisplay.FormatHostTime(source.LastEventTime, source.HostTimezone ?? Model.Coverage?.HostTimezone ?? Model.Summary.HostTimezone, "yyyy-MM-dd HH:mm")
                                    <div class="muted">@TimeDisplay.HostTimezoneLabel(source.HostTimezone ?? Model.Coverage?.HostTimezone ?? Model.Summary.HostTimezone)</div>
                                    @if (source.ObservedAt.HasValue)
                                    {
                                        <div class="muted">successful observation @TimeDisplay.FormatUtc(source.ObservedAt, "yyyy-MM-dd HH:mm")</div>
                                    }
                                </td>
                                <td>
                                    <div>rate @(source.EventRatePerMinute?.ToString("0.###") ?? "unknown")/min</div>
                                    <div>lag @(source.LagSeconds?.ToString() ?? "unknown")s</div>
                                    <div>silence @(source.SilenceSeconds?.ToString() ?? "unknown")s</div>
                                    <div class="muted mono">collected @(source.CollectedCheckpoint?.Cursor ?? source.CollectedCheckpoint?.Sequence?.ToString() ?? "unknown")</div>
                                    <div class="muted mono">acked @(source.AcknowledgedCheckpoint?.Cursor ?? source.AcknowledgedCheckpoint?.Sequence?.ToString() ?? "unknown")</div>
                                    @if (source.GapCount.GetValueOrDefault() > 0 || source.DroppedEvents.GetValueOrDefault() > 0)
                                    {
                                        <div><span class="badge warning">gap/drop @source.GapCount.GetValueOrDefault()/@source.DroppedEvents.GetValueOrDefault()</span></div>
                                    }
                                </td>
                                <td>
                                    <span>@(string.IsNullOrWhiteSpace(source.SourceVersion) ? "—" : source.SourceVersion)</span>
                                    @if (!string.IsNullOrWhiteSpace(source.ConfigHash))
                                    {
                                        var shortHash = source.ConfigHash.Length > 12 ? source.ConfigHash[..12] : source.ConfigHash;
                                        <div class="muted mono">hash @shortHash</div>
                                    }
                                    @if (source.Details.TryGetValue("source_pack", out var sourcePack))
                                    {
                                        <div class="muted">@sourcePack</div>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(source.TransitionState))
                                    {
                                        <div class="muted">transition @source.TransitionState</div>
                                    }
                                </td>
                                <td><strong>@source.Reason</strong><div class="muted">@DetailModel.SourceStateGuidance(source)</div></td>
                                <td><a href="@source.EventSearchUrl">events</a></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>

    @if (Model.Coverage is not null)
    {
        <section class="table-card" id="inventory" aria-labelledby="inventory-coverage-title">
            <div class="table-title">
                <div>
                    <h2 id="inventory-coverage-title">Inventory and posture snapshots</h2>
                    <p class="muted">Completeness states come from telemetry coverage. Latest-vs-previous changes are bounded and time-labelled; missing evidence never implies complete host posture.</p>
                </div>
            </div>
            <div class="table-scroll">
                <table>
                    <caption>Inventory and audit-policy snapshot completeness states</caption>
                    <thead><tr><th>Snapshot</th><th>Status</th><th>Latest</th><th>Items</th><th>Reason</th><th>Review</th></tr></thead>
                    <tbody>
                    @foreach (var snapshot in Model.Coverage.Inventory)
                    {
                        <tr>
                            <td>@snapshot.SnapshotType</td>
                            <td><span class="badge @(snapshot.Status is "healthy" or "not_applicable" or "excepted" ? "ok" : snapshot.Status is "missing" or "stale" or "degraded" ? "warning" : "danger")">@snapshot.Status</span></td>
                            <td>
                                @TimeDisplay.FormatHostTime(snapshot.LatestCollectedAt, snapshot.HostTimezone ?? Model.Coverage.HostTimezone, "yyyy-MM-dd HH:mm")
                                <div class="muted">@TimeDisplay.HostTimezoneLabel(snapshot.HostTimezone ?? Model.Coverage.HostTimezone)</div>
                            </td>
                            <td>@snapshot.ItemCount</td>
                            <td>@snapshot.Reason</td>
                            <td>
                                @if (snapshot.Url.StartsWith("/api/", StringComparison.OrdinalIgnoreCase))
                                {
                                    <span class="muted">API (operator credential required)</span>
                                }
                                else
                                {
                                    <a href="@snapshot.Url">open</a>
                                }
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </section>

        <section class="table-card" aria-labelledby="inventory-change-title">
            <div class="table-title">
                <div>
                    <h2 id="inventory-change-title">Bounded inventory/posture changes</h2>
                    <p class="muted">Change previews are capped at 20 snapshot types and 8 changes per type. Non-admin roles see item identities and metadata values redacted.</p>
                </div>
            </div>
            @if (Model.InventorySnapshots.Count == 0)
            {
                <div class="empty"><strong>No inventory snapshots are stored for this host.</strong><p>This is an unknown posture state, not evidence that the host has no users, packages, services, listeners, or policy drift.</p></div>
            }
            else
            {
                <div class="table-scroll">
                    <table>
                        <caption>Latest and previous bounded inventory snapshots with role-redacted change summaries</caption>
                        <thead><tr><th>Snapshot</th><th>Status</th><th>Current / previous</th><th>Items</th><th>Changes</th><th>Redaction</th></tr></thead>
                        <tbody>
                        @foreach (var snapshot in Model.InventorySnapshots)
                        {
                            <tr>
                                <td>@snapshot.SnapshotType</td>
                                <td><span class="badge @snapshot.Status">@snapshot.Status</span></td>
                                <td>
                                    <div>current @TimeDisplay.FormatHostTime(snapshot.CurrentCollectedAt, snapshot.HostTimezone ?? Model.Coverage.HostTimezone, "yyyy-MM-dd HH:mm")</div>
                                    <div class="muted">previous @TimeDisplay.FormatHostTime(snapshot.PreviousCollectedAt, snapshot.HostTimezone ?? Model.Coverage.HostTimezone, "yyyy-MM-dd HH:mm")</div>
                                </td>
                                <td>@snapshot.CurrentItemCount current / @snapshot.PreviousItemCount previous</td>
                                <td>
                                    <div>@snapshot.AddedCount added / @snapshot.RemovedCount removed / @snapshot.ChangedCount changed</div>
                                    @if (snapshot.Changes.Count == 0)
                                    {
                                        <div class="muted">No bounded item-level changes between the two latest snapshots.</div>
                                    }
                                    else
                                    {
                                        <ul class="compact-list">
                                        @foreach (var change in snapshot.Changes)
                                        {
                                            <li><span class="badge neutral">@change.ChangeType</span> @change.Kind — @change.DisplayName <span class="muted">@change.Status; @change.MetadataSummary</span></li>
                                        }
                                        </ul>
                                    }
                                </td>
                                <td>@snapshot.RedactionLabel</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
        </section>

        <section class="table-card" id="detections" aria-labelledby="detection-prereq-title">
            <div class="table-title">
                <div>
                    <h2 id="detection-prereq-title">Detection prerequisite status</h2>
                    <p class="muted">Platform-applicable Windows or Linux built-in detection rules are compared with source health, recent event presence, inventory, and audit-policy prerequisites. Missing evidence remains a visible detection gap.</p>
                </div>
            </div>
            <div class="table-scroll">
                <table>
                    <caption>Detection prerequisite coverage for implemented built-in rules</caption>
                    <thead><tr><th>Rule</th><th>Status</th><th>Required sources</th><th>Recent source events</th><th>Missing/stale</th><th>Reason</th></tr></thead>
                    <tbody>
                    @foreach (var rule in Model.Coverage.DetectionPrerequisites)
                    {
                        <tr>
                            <td><strong>@rule.Name</strong><div class="muted mono">@rule.RuleId · @rule.Severity</div></td>
                            <td><span class="badge @(rule.Status == "satisfied" ? "ok" : rule.Status == "unknown" || rule.Status == "partially_satisfied" ? "warning" : "danger")">@rule.Status</span></td>
                            <td>@string.Join(", ", rule.RequiredSources)</td>
                            <td>@(rule.RecentEventSources.Count == 0 ? "—" : string.Join(", ", rule.RecentEventSources))</td>
                            <td>@string.Join(", ", rule.MissingSources.Concat(rule.StaleSources).Distinct())</td>
                            <td>@rule.Reason</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </section>
    }
}
