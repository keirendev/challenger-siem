@page "/soc-agent"
@model Challenger.Siem.Api.Pages.SocAgentModel
@{
    ViewData["Title"] = "soc-agent";
    ViewData["MainClass"] = "soc-agent-page";

    var contextAgentId = string.IsNullOrWhiteSpace(Model.ContextAgentId)
        ? null
        : Model.ContextAgentId.Trim();
    var activeSessionId = Model.CurrentSession?.SessionId ?? Model.SessionId;
    var selectedModel = Model.ProviderStatus.ModelOptions.FirstOrDefault(option =>
            string.Equals(option.Model, Model.SelectedModel, StringComparison.OrdinalIgnoreCase))
        ?? Model.ProviderStatus.ModelOptions.FirstOrDefault();
    var selectedEfforts = selectedModel?.ReasoningEfforts ?? Array.Empty<string>();
    var providerStatusLabel = Model.ProviderStatus.Status.Replace('_', ' ');
    var configuredConnectUrl = Model.ProviderStatus.ConnectUrl?.Trim();
    var safeConnectUrl = !string.IsNullOrWhiteSpace(configuredConnectUrl)
        && ((configuredConnectUrl.StartsWith("/", StringComparison.Ordinal) && !configuredConnectUrl.StartsWith("//", StringComparison.Ordinal))
            || (Uri.TryCreate(configuredConnectUrl, UriKind.Absolute, out var connectUri)
                && (connectUri.Scheme == Uri.UriSchemeHttps || connectUri.Scheme == Uri.UriSchemeHttp)))
        ? configuredConnectUrl
        : null;
    var configuredChatGptVerificationUrl = Model.ChatGptLoginStatus.VerificationUrl;
    var safeChatGptVerificationUrl = Uri.TryCreate(configuredChatGptVerificationUrl, UriKind.Absolute, out var chatGptVerificationUri)
        && chatGptVerificationUri.Scheme == Uri.UriSchemeHttps
        && string.Equals(chatGptVerificationUri.Host, "auth.openai.com", StringComparison.OrdinalIgnoreCase)
        && chatGptVerificationUri.IsDefaultPort
        && string.IsNullOrEmpty(chatGptVerificationUri.UserInfo)
        && string.Equals(chatGptVerificationUri.AbsolutePath, "/codex/device", StringComparison.Ordinal)
        && string.IsNullOrEmpty(chatGptVerificationUri.Query)
        && string.IsNullOrEmpty(chatGptVerificationUri.Fragment)
        ? chatGptVerificationUri.AbsoluteUri
        : null;
}

@section Head {
    <link rel="stylesheet" href="~/css/soc-agent.css" asp-append-version="true" />
}

<header class="soc-agent-header">
    <h1>soc-agent</h1>
    <div class="soc-agent-header-actions">
        <span id="soc-agent-provider-pill" class="badge @Model.StatusBadgeClass()">@providerStatusLabel</span>
        <a class="button secondary small" asp-page="/SocAgent" asp-route-agent_id="@contextAgentId">New chat</a>
        <button id="soc-agent-settings-button" class="button secondary small" type="button" data-open-dialog="soc-agent-settings-dialog">Settings</button>
    </div>
</header>

@if (!string.IsNullOrWhiteSpace(Model.NoticeMessage))
{
    <div class="alert success" role="status">@Model.NoticeMessage</div>
}
@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert error" role="alert">@Model.ErrorMessage</div>
}
<div id="soc-agent-live-alert" class="alert error" role="alert" hidden></div>

@if (Model.ShouldShowProviderInlineNotice)
{
    <section id="soc-agent-provider-inline-notice" class="soc-agent-provider-notice" aria-label="Provider attention required">
        <div>
            <strong id="soc-agent-provider-inline-name">@Model.ProviderStatus.DisplayName</strong>
            <span id="soc-agent-provider-inline-message">@Model.ProviderStatus.Message</span>
        </div>
        <button id="soc-agent-provider-settings-button" class="button secondary small" type="button" data-open-dialog="soc-agent-settings-dialog">Review settings</button>
    </section>
}

<dialog id="soc-agent-settings-dialog" class="soc-agent-settings-dialog" aria-labelledby="soc-agent-settings-title">
    <div class="settings-dialog-header">
        <div>
            <p class="eyebrow">soc-agent</p>
            <h2 id="soc-agent-settings-title">ChatGPT settings</h2>
        </div>
        <button class="dialog-close" type="button" aria-label="Close settings" data-close-dialog>×</button>
    </div>

    <div class="settings-dialog-body">
        <section class="settings-section" aria-labelledby="subscription-settings-title">
            <div class="settings-section-heading">
                <div>
                    <h3 id="subscription-settings-title">Account</h3>
                    <p>Manage the ChatGPT subscription used by this SIEM instance.</p>
                </div>
                <span id="soc-agent-settings-provider-status" class="badge @Model.StatusBadgeClass()">@providerStatusLabel</span>
            </div>

            <div class="settings-account-summary">
                <strong id="soc-agent-settings-provider-name">@Model.ProviderStatus.DisplayName</strong>
                <p id="soc-agent-settings-provider-message">@Model.ProviderStatus.Message</p>
            </div>

            <dl class="settings-metadata">
                <div><dt>Provider</dt><dd>@Model.ProviderStatus.Provider</dd></div>
                <div><dt>Authentication</dt><dd>@Model.AuthenticationLabel</dd></div>
                @if (!string.IsNullOrWhiteSpace(Model.ProviderStatus.CredentialSource))
                {
                    <div><dt>Credential source</dt><dd>@Model.ProviderStatus.CredentialSource</dd></div>
                }
                @if (Model.ProviderStatus.ExpiresAt.HasValue)
                {
                    <div><dt>Expires</dt><dd>@Model.ProviderStatus.ExpiresAt.Value.ToLocalTime().ToString("d MMM yyyy, HH:mm")</dd></div>
                }
                @if (!string.IsNullOrWhiteSpace(Model.ProviderStatus.RefreshStatus))
                {
                    <div><dt>Refresh</dt><dd>@Model.ProviderStatus.RefreshStatus.Replace('_', ' ')</dd></div>
                }
                @if (!string.IsNullOrWhiteSpace(Model.ProviderStatus.ScopeStatus))
                {
                    <div><dt>Scope</dt><dd>@Model.ProviderStatus.ScopeStatus.Replace('_', ' ')</dd></div>
                }
                @if (!string.IsNullOrWhiteSpace(Model.ProviderStatus.EntitlementStatus))
                {
                    <div><dt>Entitlement</dt><dd>@Model.ProviderStatus.EntitlementStatus.Replace('_', ' ')</dd></div>
                }
            </dl>

            @if (Model.ProviderStatus.DataMayLeaveLocalSiem)
            {
                <p class="settings-data-note">Prompts and selected SIEM context may be sent to the configured provider. Credentials stay server-side and are never exposed to this page.</p>
            }
            else
            {
                <p class="settings-data-note">Analysis remains inside the local SIEM provider path.</p>
            }

            <div class="settings-actions">
                @if (Model.CanStartSubscriptionOAuthConnect)
                {
                    <form method="post" asp-page-handler="ConnectSubscriptionOAuth">
                        <button class="button" type="submit">@(Model.ProviderStatus.Status == "connected" ? "Reconnect ChatGPT" : "Connect ChatGPT")</button>
                    </form>
                }
                else if (Model.CanManageProviderAuthentication && !string.IsNullOrWhiteSpace(safeConnectUrl))
                {
                    <a class="button" href="@safeConnectUrl" rel="noopener noreferrer">@(Model.ProviderStatus.ConnectLabel ?? "Connect provider")</a>
                }
            </div>

            @if (Model.UsesCodexManagedLogin)
            {
                <div id="soc-agent-chatgpt-login-panel"
                     class="settings-device-login"
                     tabindex="-1"
                     data-status-url="@(Model.CanManageChatGptLogin ? Url.Page("/SocAgent", "ChatGptLoginStatus") : null)"
                     data-auto-open="@Model.OpenChatGptLoginSettings.ToString().ToLowerInvariant()"
                     data-poll="@(Model.CanManageChatGptLogin && Model.ChatGptLoginStatus.IsActive ? "true" : "false")">
                    <div class="settings-device-login-header">
                        <div>
                            <strong>SIEM-managed ChatGPT login</strong>
                            <p>OpenAI Codex manages the shared ChatGPT subscription used by soc-agent on this SIEM.</p>
                        </div>
                        <span id="soc-agent-chatgpt-login-state" class="badge">@Model.ChatGptLoginStatus.State.Replace('_', ' ')</span>
                    </div>

                    <p id="soc-agent-chatgpt-login-message" class="settings-device-login-status" role="status" aria-live="polite">@Model.ChatGptLoginStatus.OperatorMessage</p>

                    @if (Model.CanManageChatGptLogin)
                    {
                        <div id="soc-agent-chatgpt-login-verification"
                             class="settings-device-login-code"
                             hidden="@(string.IsNullOrWhiteSpace(safeChatGptVerificationUrl) || string.IsNullOrWhiteSpace(Model.ChatGptLoginStatus.UserCode))">
                            <span>Enter this one-time code on OpenAI</span>
                            <code id="soc-agent-chatgpt-login-code">@Model.ChatGptLoginStatus.UserCode</code>
                            <a id="soc-agent-chatgpt-login-link" class="button secondary small" href="@safeChatGptVerificationUrl" target="_blank" rel="noopener noreferrer">Open ChatGPT sign-in</a>
                        </div>

                        <form id="soc-agent-chatgpt-login-start"
                              method="post"
                              asp-page-handler="StartChatGptLogin"
                              hidden="@(!Model.ChatGptLoginStatus.IsAvailable || Model.ChatGptLoginStatus.IsActive)">
                            <input type="hidden" name="SessionId" value="@activeSessionId" />
                            <label class="confirmation-control">
                                <input type="checkbox" name="ConfirmSharedChatGptLogin" value="true" required />
                                <span>I understand this replaces the shared server login for all soc-agent users.</span>
                            </label>
                            <button class="button" type="submit">@(Model.ProviderStatus.Status == "connected" ? "Log in to ChatGPT again" : "Log in to ChatGPT")</button>
                        </form>

                        <form id="soc-agent-chatgpt-login-cancel"
                              method="post"
                              asp-page-handler="CancelChatGptLogin"
                              hidden="@(!Model.ChatGptLoginStatus.IsActive)">
                            <input type="hidden" name="SessionId" value="@activeSessionId" />
                            <button class="button secondary small" type="submit">Cancel login</button>
                        </form>
                    }
                    else
                    {
                        <p class="settings-device-login-help">An administrator can start or cancel this shared login. Your ChatGPT password is entered only on OpenAI's page.</p>
                    }
                </div>
            }
            @if (Model.CanDisconnectSubscriptionOAuth)
            {
                <details class="settings-danger-zone">
                    <summary>Disconnect this SIEM</summary>
                    <p>This removes only the dedicated soc-agent subscription credential. It does not change your ChatGPT account or other server logins.</p>
                    <form method="post" asp-page-handler="DisconnectSubscriptionOAuth">
                        <input type="hidden" name="SessionId" value="@activeSessionId" />
                        <label class="confirmation-control">
                            <input type="checkbox" name="ConfirmSubscriptionDisconnect" value="true" required />
                            <span>I understand this SIEM will lose ChatGPT access.</span>
                        </label>
                        <button class="button danger" type="submit">Disconnect ChatGPT</button>
                    </form>
                </details>
            }
        </section>

        <section class="settings-section" aria-labelledby="model-settings-title">
            <div class="settings-section-heading">
                <div>
                    <h3 id="model-settings-title">Models</h3>
                    <p>@Model.ProviderStatus.ModelOptions.Count server-approved option@(Model.ProviderStatus.ModelOptions.Count == 1 ? string.Empty : "s") available in chat.</p>
                </div>
            </div>
            <p class="settings-managed-note">Model and effort controls are set per message. The server validates every selection and remains authoritative.</p>
        </section>
    </div>
</dialog>

<div class="soc-agent-workspace"
     data-soc-agent-workspace
     data-session-id="@activeSessionId"
     data-context-agent-id="@contextAgentId"
     data-start-url="/soc-agent/live/runs"
     data-max-message-length="4000">
    <section class="soc-agent-conversation" aria-label="soc-agent chat">
        <span id="soc-agent-run-state" class="visually-hidden" aria-live="polite">Ready</span>

        <div id="soc-agent-connection-banner" class="soc-agent-connection-banner" role="status" hidden>
            <span id="soc-agent-connection-message">Live updates disconnected.</span>
            <button id="soc-agent-reconnect" class="button secondary small" type="button">Reconnect</button>
        </div>

        <div id="soc-agent-thread-scroll" class="conversation-scroll" tabindex="0" aria-label="Chat transcript">
            <button id="soc-agent-scroll-latest" class="button tertiary small conversation-latest" type="button" hidden>Latest</button>
            <div id="soc-agent-empty-state" class="soc-agent-empty" @(Model.Messages.Count > 0 ? "hidden" : null)>
                <div>
                    <p class="eyebrow">Read-only analysis</p>
                    <h3>What should we investigate?</h3>
                    <p>soc-agent can search the SIEM using bounded tools and cite the records it used.</p>
                </div>
                <div class="prompt-grid" aria-label="Suggested prompts">
                    <button type="button" data-soc-agent-prompt="Summarize the most important recent security events.">Summarize recent security events</button>
                    <button type="button" data-soc-agent-prompt="Which agents need attention and why?">Find agents needing attention</button>
                    <button type="button" data-soc-agent-prompt="Review recent authentication failures for suspicious patterns.">Review authentication failures</button>
                    <button type="button" data-soc-agent-prompt="Show recent high-severity alerts and the evidence behind them.">Review high-severity alerts</button>
                </div>
            </div>

            <ol id="soc-agent-message-list" class="message-list" aria-live="polite">
                @foreach (var message in Model.Messages)
                {
                    var isOperator = string.Equals(message.Role, "operator", StringComparison.OrdinalIgnoreCase);
                    <li id="message-@message.MessageId" class="message-row @(isOperator ? "operator" : "assistant")" data-message-id="@message.MessageId" data-role="@message.Role">
                        <article>
                            <header class="message-meta">
                                <span class="message-role">@Model.RoleLabel(message)</span>
                                <time datetime="@message.CreatedAt.ToString("O")">@message.CreatedAt.ToLocalTime().ToString("HH:mm")</time>
                                @if (!isOperator && !string.IsNullOrWhiteSpace(message.Model))
                                {
                                    <span class="message-model">@message.Provider · @message.Model@(string.IsNullOrWhiteSpace(message.ReasoningEffort) ? string.Empty : $" · {message.ReasoningEffort}")</span>
                                }
                            </header>
                            @if (Model.ShouldRenderMarkdown(message))
                            {
                                <div class="message-content message-box markdown-content" data-soc-agent-markdown data-message-markdown="true">@message.Content</div>
                            }
                            else
                            {
                                <p class="message-content message-box">@message.Content</p>
                            }

                            @if (message.Citations.Count > 0)
                            {
                                <div class="message-citations">
                                    <span>Sources</span>
                                    <ul>
                                        @foreach (var citation in message.Citations)
                                        {
                                            <li><a href="@citation.Url">@citation.Label</a></li>
                                        }
                                    </ul>
                                </div>
                            }
                        </article>
                    </li>
                }
            </ol>
        </div>

        <form id="soc-agent-composer" class="soc-agent-composer" method="post" asp-page-handler="Send">
            <input id="soc-agent-session-id" type="hidden" name="SessionId" value="@activeSessionId" />
            <input id="soc-agent-context-agent-id" type="hidden" name="ComposerContextAgentId" value="@contextAgentId" />
            <label class="visually-hidden" for="soc-agent-message">Message soc-agent</label>
            <textarea id="soc-agent-message" name="Message" maxlength="4000" rows="3" required placeholder="Ask about events, agents, alerts, or recent activity…"></textarea>
            <div class="composer-footer">
                <div class="composer-context">
                    @if (!string.IsNullOrWhiteSpace(contextAgentId))
                    {
                        <span class="context-chip">Agent context</span>
                    }
                    else
                    {
                        <span class="context-chip neutral">All permitted SIEM data</span>
                    }
                    <span id="soc-agent-character-count">0 / 4000</span>
                </div>
                <div class="composer-controls">
                    <label class="composer-select" for="soc-agent-model-select">
                        <span>Model</span>
                        <select id="soc-agent-model-select" name="SelectedModel">
                            @foreach (var option in Model.ProviderStatus.ModelOptions)
                            {
                                if (string.Equals(option.Model, Model.SelectedModel, StringComparison.OrdinalIgnoreCase))
                                {
                                    <option value="@option.Model" data-reasoning-efforts="@string.Join(',', option.ReasoningEfforts)" data-default-reasoning-effort="@option.DefaultReasoningEffort" selected>@option.DisplayName</option>
                                }
                                else
                                {
                                    <option value="@option.Model" data-reasoning-efforts="@string.Join(',', option.ReasoningEfforts)" data-default-reasoning-effort="@option.DefaultReasoningEffort">@option.DisplayName</option>
                                }
                            }
                        </select>
                    </label>
                    <label class="composer-select" for="soc-agent-effort-select">
                        <span>Effort</span>
                        <select id="soc-agent-effort-select" name="ReasoningEffort" disabled="@(selectedEfforts.Count == 0)">
                            @if (selectedEfforts.Count == 0)
                            {
                                <option value="">Not available</option>
                            }
                            else
                            {
                                @foreach (var effort in selectedEfforts)
                                {
                                    if (string.Equals(effort, Model.ReasoningEffort, StringComparison.OrdinalIgnoreCase))
                                    {
                                        <option value="@effort" selected>@effort</option>
                                    }
                                    else
                                    {
                                        <option value="@effort">@effort</option>
                                    }
                                }
                            }
                        </select>
                    </label>
                    <button id="soc-agent-cancel" class="button secondary" type="button" hidden>Cancel</button>
                    <button id="soc-agent-send" class="button" type="submit">Send</button>
                </div>
            </div>
            <p class="composer-hint">Enter to send · Shift+Enter for a new line · Read-only tools</p>
        </form>
    </section>

    <aside class="soc-agent-history" aria-labelledby="soc-agent-history-title">
        <div class="history-header">
            <h2 id="soc-agent-history-title">Recent chats</h2>
            <span>@Model.Sessions.Count</span>
        </div>
        @if (Model.Sessions.Count == 0)
        {
            <p class="history-empty">Your recent investigations will appear here.</p>
        }
        else
        {
            <ol class="history-list">
                @foreach (var session in Model.Sessions)
                {
                    var isCurrent = Model.CurrentSession?.SessionId == session.SessionId;
                    <li class="history-item @(isCurrent ? "current" : null)">
                        <a asp-page="/SocAgent" asp-route-session_id="@session.SessionId" aria-current="@(isCurrent ? "page" : null)">
                            <strong>@session.Title</strong>
                            <span>@session.MessageCount message@(session.MessageCount == 1 ? string.Empty : "s") · @session.Model</span>
                            <time datetime="@session.UpdatedAt.ToString("O")">@session.UpdatedAt.ToLocalTime().ToString("d MMM, HH:mm")</time>
                        </a>
                        <form class="history-delete-form" method="post" asp-page-handler="DeleteSession">
                            <input type="hidden" name="DeleteSessionId" value="@session.SessionId" />
                            <input type="hidden" name="ConfirmDelete" value="true" />
                            <button class="history-delete-button"
                                    type="submit"
                                    aria-label="Delete chat: @session.Title"
                                    title="Delete chat">×</button>
                        </form>
                    </li>
                }
            </ol>
        }
    </aside>
</div>

@section Scripts {
    <script src="~/js/soc-agent.js" asp-append-version="true"></script>
}
