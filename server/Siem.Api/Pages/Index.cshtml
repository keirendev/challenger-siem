@page "/"
@model IndexModel
@{
    ViewData["Title"] = "Overview";
}

<partial name="_Breadcrumbs" model='BreadcrumbsModel.Create(new BreadcrumbItem("Overview", IsCurrent: true))' />

<div class="page-header">
    <div>
        <p class="page-kicker">Operations overview</p>
        <h1>Overview</h1>
        <p class="muted">Dashboard metrics for ingestion, endpoint health, queue pressure, source gaps, and managed telemetry capacity.</p>
    </div>
    <div class="actions">
        <a class="button secondary" asp-page="/Agents/Index" asp-route-health="stale">Review stale agents</a>
        <a class="button" asp-page="/Events/Index">Review events</a>
    </div>
</div>

@if (Model.ErrorMessage is not null)
{
    <partial name="_Notice" model='new NoticeModel("Overview unavailable", Model.ErrorMessage, "error", IsAlert: true)' />
}
else if (Model.Summary.ActiveAgents == 0 && Model.Summary.RecentEventCount == 0)
{
    <partial name="_Notice" model='new NoticeModel("No telemetry yet", "No active agents or recent events are visible. Register a synthetic agent or review setup before treating this as a healthy quiet state.", "empty")' />
}

<partial name="_LifecycleStates" model='new LifecycleStatesModel("Overview lifecycle states", new[] { new LifecycleStateModel("loading", "Loading", "Metric skeletons preserve layout during refresh."), new LifecycleStateModel("degraded", "Degraded", "Stale agents, queue pressure, and storage warnings stay visible.", "warning"), new LifecycleStateModel("success", "Success", "Counts are bounded and link to the implemented review surfaces.", "ok") })' />

<section class="metrics" aria-label="Dashboard metrics">
    <article class="card">
        <span class="metric-value">@Model.Summary.ActiveAgents</span>
        <span class="metric-label">active agents</span>
    </article>
    <article class="card">
        <span class="metric-value">@Model.Summary.RecentActiveAgents</span>
        <span class="metric-label">recent active agents</span>
    </article>
    <article class="card">
        <span class="metric-value">@Model.Summary.StaleActiveAgents</span>
        <span class="metric-label">stale active agents</span>
    </article>
    <article class="card">
        <span class="metric-value">@Model.Summary.RetiredAgents</span>
        <span class="metric-label">retired agents</span>
    </article>
    <article class="card">
        <span class="metric-value">@Model.Summary.HistoricalAgents</span>
        <span class="metric-label">historical registrations</span>
    </article>
    <article class="card">
        <span class="metric-value">@Model.Summary.AgentsWithQueuedEvents</span>
        <span class="metric-label">active agents with queued events</span>
    </article>
    <article class="card">
        <span class="metric-value">@Model.Summary.AgentsWithPressure</span>
        <span class="metric-label">active agents with pressure/throttle</span>
    </article>
    <article class="card">
        <span class="metric-value">@Model.Summary.AgentsWithSourceGaps</span>
        <span class="metric-label">active agents with source gaps/drops</span>
    </article>
    <article class="card">
        <span class="metric-value">@Model.Summary.AgentsWithDegradedSources</span>
        <span class="metric-label">active agents with degraded sources</span>
    </article>
    <article class="card">
        <span class="metric-value">@Model.Summary.AgentsWithCapacityWarnings</span>
        <span class="metric-label">active agents with queue capacity ≥70%</span>
    </article>
    <article class="card">
        <span class="metric-value">@Model.Summary.RecentEventCount</span>
        <span class="metric-label">events ingested in last @Model.RecentEventWindowHours h</span>
    </article>
    <article class="card">
        <span class="metric-value">@TimeDisplay.FormatUtc(Model.Summary.LatestIngestTime, "yyyy-MM-dd HH:mm")</span>
        <span class="metric-label">latest ingest time (UTC)</span>
    </article>
</section>

<section class="card">
    <h2>Health interpretation</h2>
    <p>
        Active agents are marked stale when they have not been seen for @Model.StaleAgentMinutes minutes.
        Retired agents are disabled registrations hidden from default active views; their historical events and heartbeat data are preserved.
        Non-zero queue depth, pressure, gap, and capacity counts are taken from latest heartbeat/source-health observations for active agents.
    </p>
    <p>
        Managed telemetry storage state is <strong>@(Model.StorageAccounting?.WarningState ?? "unknown")</strong>
        at @(Model.StorageAccounting?.UsedPercent.ToString("0.###") ?? "unknown")% of configured capacity.
        Capacity warnings are textual and non-color-only: 70% warning, 85% warning, 95% critical, and 100% over capacity.
        Retention lag: @(Model.StorageAccounting?.RetentionLagState ?? "unknown").
    </p>
</section>
