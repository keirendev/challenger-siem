@page "/login"
@model LoginModel
@{
    ViewData["Title"] = "Operator login";
}

<section class="card narrow" aria-labelledby="login-title">
    <p class="page-kicker">Secure review console</p>
    <h1 id="login-title">Operator login</h1>
    <p class="muted">Enter the configured review token to access the SIEM review console. The token is validated server-side and the browser receives an HTTP-only session cookie.</p>

    @if (Model.ErrorMessage is not null)
    {
        <div class="alert" role="alert">@Model.ErrorMessage</div>
    }

    <form method="post">
        <input type="hidden" asp-for="ReturnUrl" />
        <div class="form-row">
            <label for="review-token">Review token</label>
            <input id="review-token" name="ReviewToken" type="password" autocomplete="current-password" autofocus />
        </div>
        <p class="muted">Do not paste review tokens into URLs, logs, screenshots, or issue comments.</p>
        <p>
            <button type="submit">Sign in</button>
        </p>
    </form>
</section>
