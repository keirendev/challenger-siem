@page "/alerts/detail"
@model Challenger.Siem.Api.Pages.Alerts.DetailModel
@{
    ViewData["Title"] = "Alert detail";
}

<partial name="_Breadcrumbs" model='BreadcrumbsModel.Create(new BreadcrumbItem("Overview", Page: "/Index"), new BreadcrumbItem("Alerts", Page: "/Alerts/Index"), new BreadcrumbItem("Alert detail", IsCurrent: true))' />

<div class="page-header">
    <div><p class="page-kicker">Detection drill-down</p><h1>Alert detail</h1><p class="muted">Detection metadata, affected entities, and linked evidence.</p></div>
    <a class="button secondary" asp-page="/Alerts/Index">Back to alerts</a>
</div>

@if (Model.ErrorMessage is not null)
{
    <partial name="_Notice" model='new NoticeModel("Alert unavailable", Model.ErrorMessage, "error", IsAlert: true)' />
}
else if (Model.Alert is not null)
{
    <partial name="_Tabs" model='new TabsModel("Alert detail sections", new[] { new TabItem("Summary", "#summary", true), new TabItem("Entities", "#entities"), new TabItem("Evidence", "#evidence"), new TabItem("Case links", "#", IsDisabled: true, Description: "Case management is planned.") })' />
    <section class="card" id="summary">
        <h2>@Model.Alert.Title</h2>
        <dl class="detail-grid">
            <dt>Rule</dt><dd>@Model.Alert.RuleId v@Model.Alert.RuleVersion</dd>
            <dt>Severity</dt><dd>@Model.Alert.Severity</dd>
            <dt>Confidence</dt><dd>@Model.Alert.Confidence</dd>
            <dt>Status</dt><dd>@Model.Alert.Status</dd>
            <dt>Host</dt><dd>@(Model.Alert.Hostname ?? Model.Alert.AgentId ?? "—")</dd>
            <dt>Created</dt><dd>@TimeDisplay.FormatUtc(Model.Alert.CreatedAt)</dd>
        </dl>
        <p>@Model.Alert.Summary</p>
    </section>

    <section class="card" id="entities">
        <h2>Affected entities</h2>
        @if (Model.Alert.AffectedEntities.Count == 0)
        {
            <p class="muted">No affected entities are linked.</p>
        }
        else
        {
            <ul>
                @foreach (var entity in Model.Alert.AffectedEntities)
                {
                    <li><strong>@entity.Type</strong> @entity.Value <span class="muted">@entity.Role</span></li>
                }
            </ul>
        }
    </section>

    <section class="table-card" id="evidence">
        <div class="table-title"><h2>Evidence</h2></div>
        @if (Model.Alert.Evidence.Count == 0)
        {
            <div class="empty">No evidence rows are linked.</div>
        }
        else
        {
            <div class="table-scroll">
            <table>
                <caption>Alert evidence with event time, agent, source channel, event ID, redaction-aware summary, and event pivot</caption>
                <thead><tr><th>Event time</th><th>Agent</th><th>Channel</th><th>Event ID</th><th>Summary</th><th></th></tr></thead>
                <tbody>
                    @foreach (var evidence in Model.Alert.Evidence)
                    {
                        <tr>
                            <td>
                                @TimeDisplay.FormatHostTime(evidence.EventTime, evidence.HostTimezone)
                                <div class="muted">@TimeDisplay.HostTimezoneLabel(evidence.HostTimezone)</div>
                            </td>
                            <td>@evidence.AgentId</td>
                            <td>@(evidence.Channel ?? "—")</td>
                            <td>@(evidence.WindowsEventId?.ToString() ?? "—")</td>
                            <td>@evidence.Summary</td>
                            <td><a asp-page="/Events/Detail" asp-route-agent_id="@evidence.AgentId" asp-route-event_id="@evidence.EventId">Open event</a></td>
                        </tr>
                    }
                </tbody>
            </table>
            </div>
        }
    </section>
}
