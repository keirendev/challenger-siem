@page "/alerts"
@model Challenger.Siem.Api.Pages.Alerts.IndexModel
@{
    ViewData["Title"] = "Alerts";
}

<partial name="_Breadcrumbs" model='BreadcrumbsModel.Create(new BreadcrumbItem("Overview", Page: "/Index"), new BreadcrumbItem("Alerts", IsCurrent: true))' />

<div class="page-header">
    <div>
        <p class="page-kicker">Detection review</p>
        <h1>Alerts</h1>
        <p class="muted">Detection alert triage with bounded result pages, ownership, lifecycle, disposition, evidence links, and case promotion.</p>
    </div>
</div>

@if (Model.ErrorMessage is not null)
{
    <partial name="_Notice" model='new NoticeModel("Alerts unavailable", Model.ErrorMessage, "error", IsAlert: true)' />
}
<partial name="_Notice" model='new NoticeModel("Evidence behavior", "Alert evidence keeps immutable event identity and rule-version context. Evidence rows show whether telemetry is retained, removed by retention, or missing.", "info")' />

<form method="get" class="card filters filter-panel" aria-label="Alert filters">
    <div class="form-row">
        <label for="status">Status</label>
        <select id="status" asp-for="Status">
            <option value="">Any</option>
            <option value="new">New</option>
            <option value="acknowledged">Acknowledged</option>
            <option value="triaged">Triaged</option>
            <option value="investigating">Investigating</option>
            <option value="escalated">Escalated</option>
            <option value="contained">Contained</option>
            <option value="resolved">Resolved</option>
            <option value="closed">Closed</option>
            <option value="suppressed">Suppressed</option>
        </select>
    </div>
    <div class="actions"><button type="submit">Search alerts</button><a class="button secondary" asp-page="/Alerts/Index">Clear</a></div>
</form>

<section class="table-card" aria-labelledby="alerts-results-title">
<div class="table-title">
    <div>
        <h2 id="alerts-results-title">Alert results</h2>
        <p class="muted">Showing @Model.FirstResultNumber-@Model.LastResultNumber from a bounded @Challenger.Siem.Api.Pages.Alerts.IndexModel.PageSize-row page.</p>
    </div>
    <span class="pill">status: @(string.IsNullOrWhiteSpace(Model.Status) ? "any" : Model.Status)</span>
</div>
@if (Model.Alerts.Count == 0)
{
    <div class="empty"><strong>No alerts match the current filters.</strong><p>Review status filters, detection prerequisites, and telemetry coverage before treating this as no signal.</p></div>
}
else
{
    <div class="table-scroll">
    <table>
        <caption>Alert review results with severity, confidence, lifecycle status, rule identity, host, and detail pivots</caption>
        <thead>
            <tr><th>Created</th><th>Title</th><th>Severity</th><th>Confidence</th><th>Status</th><th>Rule</th><th>Host</th><th></th></tr>
        </thead>
        <tbody>
            @foreach (var alert in Model.Alerts)
            {
                <tr>
                    <td>@TimeDisplay.FormatUtc(alert.CreatedAt, "yyyy-MM-dd HH:mm")</td>
                    <td class="compact-cell"><strong>@alert.Title</strong><div class="muted">@alert.Summary</div></td>
                    <td><span class="badge danger">@alert.Severity</span></td>
                    <td>@alert.Confidence</td>
                    <td><span class="badge">@alert.Status</span></td>
                    <td>@alert.RuleId v@(alert.RuleVersion)</td>
                    <td>@(alert.Hostname ?? alert.AgentId ?? "—")</td>
                    <td><a asp-page="/Alerts/Detail" asp-route-alert_id="@alert.AlertId">Open</a></td>
                </tr>
            }
        </tbody>
    </table>
    </div>
}
<nav class="pagination" aria-label="Alert result pages">
    <span class="muted">Page @Model.PageNumber · newest alerts first</span>
    <div class="actions">
        <a class="button secondary @(Model.HasPreviousPage ? null : "disabled")" aria-disabled="@(!Model.HasPreviousPage)" asp-page="/Alerts/Index" asp-route-status="@Model.Status" asp-route-page="@(Model.PageNumber - 1)">Previous</a>
        <a class="button secondary @(Model.HasNextPage ? null : "disabled")" aria-disabled="@(!Model.HasNextPage)" asp-page="/Alerts/Index" asp-route-status="@Model.Status" asp-route-page="@(Model.PageNumber + 1)">Next</a>
    </div>
</nav>
</section>
