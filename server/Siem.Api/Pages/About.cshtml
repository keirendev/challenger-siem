@page "/about"
@model AboutModel
@{
    ViewData["Title"] = "Health";
}

<partial name="_Breadcrumbs" model='BreadcrumbsModel.Create(new BreadcrumbItem("Overview", Page: "/Index"), new BreadcrumbItem("Health", IsCurrent: true))' />

<div class="page-header">
    <div>
        <p class="page-kicker">Runtime status</p>
        <h1>Health</h1>
        <p class="muted">Runtime and compatibility information without secret values.</p>
    </div>
</div>

<partial name="_LifecycleStates" model='new LifecycleStatesModel("Health lifecycle states", new[] { new LifecycleStateModel("healthy", "Connected", "Database and version metadata are available.", "ok"), new LifecycleStateModel("degraded", "Degraded", "Open Assets for stale source or coverage gaps.", "warning"), new LifecycleStateModel("error", "Error", "Safe status text is shown without connection details.", "error") })' />

<section class="card">
    <dl class="detail-grid">
        <dt>Application version</dt><dd>@Model.ApplicationVersion</dd>
        <dt>API version</dt><dd>v1</dd>
        <dt>Schema contract version</dt><dd>contracts/v1</dd>
        <dt>Environment</dt><dd>@Model.EnvironmentName</dd>
        <dt>Database connectivity</dt>
        <dd>
            <span class="badge @(Model.Database.IsConnected ? "ok" : "danger")">@Model.Database.Message</span>
        </dd>
    </dl>
</section>
