@{
    var currentPage = (ViewContext.RouteData.Values["page"] as string) ?? string.Empty;
    var mainClass = ViewData["MainClass"] as string ?? "container";
    var operatorName = User.Identity?.Name ?? "operator";
    var operatorRole = OperatorAuthorization.Role(User) ?? "anonymous";
    var canUseAnalystWorkspaces = OperatorAuthorization.HasPermission(operatorRole, OperatorPermission.ManageInvestigations);
    var canManageOperators = OperatorAuthorization.HasPermission(operatorRole, OperatorPermission.ManageOperators);
    bool IsActive(string page) => string.Equals(currentPage, page, StringComparison.OrdinalIgnoreCase)
        || currentPage.StartsWith(page + "/", StringComparison.OrdinalIgnoreCase);
    bool IsAnyActive(params string[] pages) => pages.Any(IsActive);
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - Challenger SIEM</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Head", required: false)
</head>
<body>
    <a class="skip-link" href="#main-content">Skip to main content</a>
    <div class="app-frame">
        <header class="app-shell" role="banner">
            <a class="brand rail-brand" asp-page="/Index" aria-label="Challenger SIEM overview">
                <span class="brand-mark" aria-hidden="true">◆</span>
                <span class="brand-copy"><strong>Challenger</strong><small>SIEM</small></span>
            </a>

            @if (User.Identity?.IsAuthenticated == true)
            {
                <nav class="primary-nav" aria-label="Primary">
                    <a class="nav-item @(IsActive("/Index") ? "active" : null)" aria-label="Overview" aria-current="@(IsActive("/Index") ? "page" : null)" asp-page="/Index"><span class="nav-glyph" aria-hidden="true">OV</span><span class="nav-label">Overview</span></a>
                    <a class="nav-item @(IsActive("/Events") ? "active" : null)" aria-label="Search" aria-current="@(IsActive("/Events") ? "page" : null)" asp-page="/Events/Index"><span class="nav-glyph" aria-hidden="true">SE</span><span class="nav-label">Search</span></a>
                    <a class="nav-item @(IsAnyActive("/Agents", "/AuditPolicy") ? "active" : null)" aria-label="Assets" aria-current="@(IsAnyActive("/Agents", "/AuditPolicy") ? "page" : null)" asp-page="/Agents/Index"><span class="nav-glyph" aria-hidden="true">AS</span><span class="nav-label">Assets</span></a>
                    <a class="nav-item @(IsActive("/Alerts") ? "active" : null)" aria-label="Alerts" aria-current="@(IsActive("/Alerts") ? "page" : null)" asp-page="/Alerts/Index"><span class="nav-glyph" aria-hidden="true">AL</span><span class="nav-label">Alerts</span></a>
                    @if (canUseAnalystWorkspaces)
                    {
                        <a class="nav-item @(IsActive("/Cases") ? "active" : null)" aria-label="Cases" aria-current="@(IsActive("/Cases") ? "page" : null)" asp-page="/Cases/Index"><span class="nav-glyph" aria-hidden="true">CA</span><span class="nav-label">Cases</span></a>
                    }
                    <a class="nav-item @(IsActive("/Detections") ? "active" : null)" aria-label="Detections" aria-current="@(IsActive("/Detections") ? "page" : null)" asp-page="/Detections/Index"><span class="nav-glyph" aria-hidden="true">DE</span><span class="nav-label">Detections</span></a>
                    <a class="nav-item @(IsActive("/Dashboards") ? "active" : null)" aria-label="Dashboards" aria-current="@(IsActive("/Dashboards") ? "page" : null)" asp-page="/Dashboards/Index"><span class="nav-glyph" aria-hidden="true">DB</span><span class="nav-label">Dashboards</span></a>
                    <a class="nav-item @(IsActive("/About") ? "active" : null)" aria-label="Health" aria-current="@(IsActive("/About") ? "page" : null)" asp-page="/About"><span class="nav-glyph" aria-hidden="true">HE</span><span class="nav-label">Health</span></a>
                    @if (canManageOperators)
                    {
                        <a class="nav-item @(IsActive("/Administration") ? "active" : null)" aria-label="Administration" aria-current="@(IsActive("/Administration") ? "page" : null)" asp-page="/Administration/Index"><span class="nav-glyph" aria-hidden="true">AD</span><span class="nav-label">Administration</span></a>
                    }
                </nav>

                @if (canUseAnalystWorkspaces || canManageOperators)
                {
                    <nav class="secondary-nav" aria-label="Operator workspaces">
                        <span class="rail-section-label">Workspaces</span>
                        @if (canUseAnalystWorkspaces)
                        {
                            <a class="nav-item @(IsActive("/Graphs") ? "active" : null)" aria-label="Investigation graphs" aria-current="@(IsActive("/Graphs") ? "page" : null)" asp-page="/Graphs/Index"><span class="nav-glyph" aria-hidden="true">GR</span><span class="nav-label">Investigation graphs</span></a>
                            <a class="nav-item @(IsActive("/SocAgent") ? "active" : null)" aria-label="soc-agent" aria-current="@(IsActive("/SocAgent") ? "page" : null)" asp-page="/SocAgent"><span class="nav-glyph analyst" aria-hidden="true">AI</span><span class="nav-label">soc-agent</span></a>
                        }
                        @if (canManageOperators)
                        {
                            <a class="nav-item @(IsActive("/AuditPolicy") ? "active" : null)" aria-label="Audit policy" aria-current="@(IsActive("/AuditPolicy") ? "page" : null)" asp-page="/AuditPolicy"><span class="nav-glyph" aria-hidden="true">AP</span><span class="nav-label">Audit policy</span></a>
                        }
                    </nav>
                }

                <div class="rail-footer">
                    <div class="operator-panel" aria-label="Current operator">
                        <span class="operator-name">@operatorName</span>
                        <span class="badge role" aria-label="Current role @operatorRole">@operatorRole</span>
                    </div>
                    <form class="logout" method="post" asp-page="/Logout">
                        <button type="submit" class="button secondary small">Sign out</button>
                    </form>
                    <p class="rail-policy">Server authorization remains authoritative.</p>
                </div>
            }
        </header>

        <div class="app-workspace">
            @if (User.Identity?.IsAuthenticated == true)
            {
                <div class="command-bar" role="region" aria-label="Console tools">
                    <form class="global-search" method="post" asp-page="/Events/Index" asp-page-handler="GlobalSearch" aria-label="Global search">
                        <label for="global-search-input">Global search</label>
                        <input id="global-search-input" name="GlobalSearch" maxlength="160" autocomplete="off" inputmode="search" placeholder="Search events, hosts, agents, or event codes" aria-describedby="global-search-help" />
                        <button type="submit" class="button">Search</button>
                        <span id="global-search-help" class="visually-hidden">Searches permitted fields in the current bounded event index without placing the query in the URL.</span>
                    </form>
                    <div class="system-strip" aria-label="System status summary">
                        <a asp-page="/About"><span class="badge ok">API v1</span></a>
                        <span class="badge neutral">contracts/v1</span>
                        <a asp-page="/Agents/Index" asp-route-health="stale"><span class="badge warning">coverage review</span></a>
                    </div>
                </div>
            }

            <main id="main-content" class="@mainClass" tabindex="-1">
                @RenderBody()
            </main>
        </div>
    </div>
    <script src="~/js/design-system.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
