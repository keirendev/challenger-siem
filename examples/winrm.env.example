# Copy to .local/winrm.env and fill in operator-approved lab values. Do not commit real credentials.
CHALLENGER_WINRM_HOST=replace-with-authorized-host
CHALLENGER_WINRM_USER=replace-with-lab-user
CHALLENGER_WINRM_PASSWORD=replace-with-lab-password

# Example WinRM settings. Select transport/authentication according to the approved lab design.
CHALLENGER_WINRM_SSL=false
CHALLENGER_WINRM_PORT=5985
CHALLENGER_WINRM_AUTH=ntlm
CHALLENGER_WINRM_CERT_VALIDATION=false

# Optional timeouts.
CHALLENGER_WINRM_CONNECTION_TIMEOUT=30
CHALLENGER_WINRM_READ_TIMEOUT=30
CHALLENGER_WINRM_OPERATION_TIMEOUT=20
