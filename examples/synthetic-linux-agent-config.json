{
  "Agent": {
    "AgentId": "synthetic-linux-01",
    "ServerBaseUrl": "https://siem.example.invalid",
    "ApiToken": "<replace-with-private-agent-token>",
    "EnrollmentToken": "",
    "HeartbeatIntervalSeconds": 60,
    "InventoryIntervalSeconds": 3600,
    "DrainBatchSize": 100,
    "Journal": {
      "Enabled": true,
      "PollIntervalSeconds": 5,
      "MaxRecordsPerPoll": 500,
      "MaxInputRecordBytes": 131072,
      "QueuePauseDepth": 100000
    },
    "Queue": {
      "Path": "/var/lib/challenger-siem-agent/queue.sqlite",
      "MaxSizeMb": 512,
      "MaxSendAttempts": 10,
      "MaxBackoffSeconds": 300,
      "WarningSizePercent": 80
    },
    "State": {
      "Path": "/var/lib/challenger-siem-agent/state.json"
    }
  }
}
