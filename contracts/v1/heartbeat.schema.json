{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://challenger-siem.local/contracts/v1/heartbeat.schema.json",
  "title": "Challenger SIEM Agent Heartbeat v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["agent_id", "hostname", "agent_version", "os", "queue_depth"],
  "properties": {
    "agent_id": { "type": "string", "minLength": 1, "maxLength": 128 },
    "hostname": { "type": "string", "minLength": 1, "maxLength": 255 },
    "agent_version": { "type": "string", "minLength": 1, "maxLength": 64 },
    "os": { "type": "string", "minLength": 1, "maxLength": 255 },
    "platform": { "$ref": "event-envelope.schema.json#/$defs/platform" },
    "host_id": { "type": "string", "minLength": 1, "maxLength": 255 },
    "last_event_time": { "type": ["string", "null"], "format": "date-time" },
    "host_timezone": { "$ref": "event-envelope.schema.json#/$defs/host_timezone" },
    "queue_depth": { "type": "integer", "minimum": 0 },
    "cpu_percent": { "type": ["number", "null"], "minimum": 0 },
    "memory_mb": { "type": ["integer", "null"], "minimum": 0 },
    "resource_metrics": { "oneOf": [{ "$ref": "#/$defs/resource_metrics" }, { "type": "null" }] },
    "config_hash": { "type": ["string", "null"], "maxLength": 128 },
    "queue_metrics": { "oneOf": [{ "$ref": "#/$defs/queue_metrics" }, { "type": "null" }] },
    "source_manifest": { "type": "array", "maxItems": 100, "x-uniquePortableBy": "source_id", "items": { "$ref": "#/$defs/source_manifest_entry" } },
    "source_health": { "type": "array", "maxItems": 100, "x-uniquePortableBy": "source_id", "items": { "$ref": "#/$defs/heartbeat_source_health_report" } },
    "tamper_checks": { "oneOf": [{ "$ref": "#/$defs/tamper_checks" }, { "type": "null" }] }
  },
  "allOf": [
    {
      "if": { "properties": { "platform": { "const": "linux" } }, "required": ["platform"] },
      "then": {
        "required": ["host_id"],
        "properties": {
          "last_event_time": { "oneOf": [{ "$ref": "event-envelope.schema.json#/$defs/required_timestamp" }, { "type": "null" }] },
          "cpu_percent": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
          "queue_metrics": {
            "oneOf": [
              { "type": "null" },
              {
                "allOf": [
                  { "$ref": "#/$defs/queue_metrics" },
                  {
                    "required": ["max_size_mb", "warning_size_percent"],
                    "properties": {
                      "last_successful_send_time": { "oneOf": [{ "$ref": "event-envelope.schema.json#/$defs/required_timestamp" }, { "type": "null" }] }
                    }
                  }
                ]
              }
            ]
          },
          "tamper_checks": { "oneOf": [{ "$ref": "#/$defs/linux_tamper_checks" }, { "type": "null" }] }
        }
      }
    },
    {
      "if": {
        "anyOf": [
          {
            "required": ["source_manifest"],
            "properties": { "source_manifest": { "contains": { "properties": { "platform": { "const": "linux" } }, "required": ["platform"] } } }
          },
          {
            "required": ["source_health"],
            "properties": { "source_health": { "contains": { "properties": { "platform": { "const": "linux" } }, "required": ["platform"] } } }
          }
        ]
      },
      "then": {
        "required": ["platform", "host_id"],
        "properties": { "platform": { "const": "linux" } }
      }
    },
    {
      "if": {
        "anyOf": [
          {
            "required": ["source_manifest"],
            "properties": { "source_manifest": { "contains": { "properties": { "source_kind": { "enum": ["linux_journal", "linux_audit", "inventory_diff", "agent_health"] } }, "required": ["source_kind"] } } }
          },
          {
            "required": ["source_health"],
            "properties": { "source_health": { "contains": { "properties": { "source_kind": { "enum": ["linux_journal", "linux_audit", "inventory_diff", "agent_health"] } }, "required": ["source_kind"] } } }
          }
        ]
      },
      "then": { "required": ["platform", "host_id"] }
    }
  ],
  "x-crossSourceIdentity": true,
  "$defs": {
    "coverage_level": { "type": "string", "enum": ["L0", "L1", "L2", "L3", "L4"] },
    "source_status": { "type": "string", "enum": ["healthy", "missing", "disabled", "stale", "degraded", "permission_denied", "unsupported", "error", "not_applicable", "excepted"] },
    "applicability": { "type": "string", "enum": ["applicable", "not_applicable", "unknown", "unsupported"] },
    "requirement": { "type": "string", "enum": ["mandatory", "optional", "role_specific"] },
    "evidence_status": { "type": "string", "enum": ["satisfied", "observed", "not_observed", "missing", "disabled", "stale", "degraded", "permission_denied", "unsupported", "not_applicable", "excepted", "unknown"] },
    "checkpoint_kind": { "type": "string", "enum": ["cursor", "sequence", "cursor_and_sequence"] },
    "source_kind": { "type": "string", "enum": ["windows_event_log", "linux_journal", "linux_audit", "inventory_diff", "agent_health"] },
    "legacy_source_list": {
      "type": "array",
      "maxItems": 32,
      "items": { "type": "string", "maxLength": 128 }
    },
    "portable_source_list": {
      "type": "array",
      "maxItems": 32,
      "items": { "type": "string", "minLength": 1, "maxLength": 128 }
    },
    "source_manifest_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_id", "display_name", "coverage_level", "required"],
      "properties": {
        "source_id": { "type": "string", "minLength": 1, "maxLength": 128 },
        "platform": { "$ref": "event-envelope.schema.json#/$defs/platform" },
        "source_kind": { "$ref": "#/$defs/source_kind" },
        "channel": { "type": "string", "minLength": 1, "maxLength": 255 },
        "source_namespace": { "type": "string", "minLength": 1, "maxLength": 128 },
        "facility": { "type": "string", "minLength": 1, "maxLength": 128 },
        "unit": { "type": "string", "minLength": 1, "maxLength": 255 },
        "applicability": { "$ref": "#/$defs/applicability" },
        "applicability_reason": { "type": "string", "minLength": 1, "maxLength": 512 },
        "checkpoint_kind": { "$ref": "#/$defs/checkpoint_kind" },
        "display_name": { "type": "string", "minLength": 1, "maxLength": 255 },
        "coverage_level": { "$ref": "#/$defs/coverage_level" },
        "required": { "type": "boolean" },
        "requirement": { "$ref": "#/$defs/requirement" },
        "applicable_roles": { "$ref": "#/$defs/portable_source_list" },
        "enabled_by_default": { "type": "boolean" },
        "source_pack": { "type": "string", "maxLength": 128 },
        "parser_id": { "type": "string", "maxLength": 128 },
        "prerequisites": { "$ref": "#/$defs/legacy_source_list" },
        "event_families": { "$ref": "#/$defs/legacy_source_list" },
        "validation_scenarios": { "$ref": "#/$defs/legacy_source_list" },
        "privacy": { "type": "string", "maxLength": 128 },
        "installer_managed": { "type": "boolean" }
      },
      "allOf": [
        {
          "if": { "not": { "required": ["source_kind"] } },
          "then": { "required": ["channel"] }
        },
        {
          "if": { "required": ["platform"] },
          "then": { "required": ["source_kind"] }
        },
        {
          "if": { "properties": { "source_kind": { "const": "windows_event_log" } }, "required": ["source_kind"] },
          "then": { "required": ["platform", "channel"], "properties": { "platform": { "const": "windows" } } }
        },
        {
          "if": { "properties": { "source_kind": { "enum": ["linux_journal", "linux_audit", "inventory_diff", "agent_health"] } }, "required": ["source_kind"] },
          "then": {
            "required": ["platform", "source_namespace", "applicability", "checkpoint_kind"],
            "properties": {
              "prerequisites": { "$ref": "#/$defs/portable_source_list" },
              "event_families": { "$ref": "#/$defs/portable_source_list" },
              "validation_scenarios": { "$ref": "#/$defs/portable_source_list" }
            },
            "not": { "required": ["channel"] }
          }
        },
        {
          "if": { "properties": { "source_kind": { "enum": ["linux_journal", "linux_audit"] } }, "required": ["source_kind"] },
          "then": { "properties": { "platform": { "const": "linux" } } }
        },
        {
          "if": { "properties": { "applicability": { "enum": ["not_applicable", "unknown", "unsupported"] } }, "required": ["applicability"] },
          "then": { "required": ["applicability_reason"] }
        }
      ]
    },
    "heartbeat_source_health_report": {
      "allOf": [
        { "$ref": "#/$defs/source_health_report" },
        {
          "if": {
            "properties": { "source_kind": { "enum": ["linux_journal", "linux_audit", "inventory_diff", "agent_health"] } },
            "required": ["source_kind"]
          },
          "then": { "properties": { "status": { "not": { "const": "excepted" } } } }
        }
      ]
    },
    "source_health_report": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_id", "display_name", "coverage_level", "status", "required", "enabled"],
      "properties": {
        "source_id": { "type": "string", "minLength": 1, "maxLength": 128 },
        "platform": { "$ref": "event-envelope.schema.json#/$defs/platform" },
        "source_kind": { "$ref": "#/$defs/source_kind" },
        "display_name": { "type": "string", "minLength": 1, "maxLength": 255 },
        "channel": { "type": "string", "minLength": 1, "maxLength": 255 },
        "source_namespace": { "type": "string", "minLength": 1, "maxLength": 128 },
        "facility": { "type": "string", "minLength": 1, "maxLength": 128 },
        "unit": { "type": "string", "minLength": 1, "maxLength": 255 },
        "applicability": { "$ref": "#/$defs/applicability" },
        "applicability_reason": { "type": "string", "minLength": 1, "maxLength": 512 },
        "coverage_level": { "$ref": "#/$defs/coverage_level" },
        "status": { "$ref": "#/$defs/source_status" },
        "required": { "type": "boolean" },
        "requirement": { "$ref": "#/$defs/requirement" },
        "applicable_roles": { "$ref": "#/$defs/portable_source_list" },
        "enabled": { "type": "boolean" },
        "last_event_time": { "type": ["string", "null"], "format": "date-time" },
        "observed_at": { "type": ["string", "null"], "format": "date-time" },
        "host_timezone": { "$ref": "event-envelope.schema.json#/$defs/host_timezone" },
        "last_record_id": { "type": ["integer", "null"], "minimum": 0 },
        "oldest_record_id": { "type": ["integer", "null"], "minimum": 0 },
        "newest_record_id": { "type": ["integer", "null"], "minimum": 0 },
        "collected_checkpoint": { "$ref": "event-envelope.schema.json#/$defs/source_checkpoint" },
        "acknowledged_checkpoint": { "$ref": "event-envelope.schema.json#/$defs/source_checkpoint" },
        "log_size_bytes": { "type": ["integer", "null"], "minimum": 0 },
        "retention_days": { "type": ["integer", "null"], "minimum": 0 },
        "lag_seconds": { "type": ["integer", "null"] },
        "silence_seconds": { "type": ["integer", "null"], "minimum": 0 },
        "event_rate_per_minute": { "type": ["number", "null"], "minimum": 0, "maximum": 1000000 },
        "error_code": { "type": ["string", "null"], "maxLength": 128 },
        "error_message": { "type": ["string", "null"], "maxLength": 1000 },
        "gap_detected": { "type": "boolean" },
        "cleared_detected": { "type": "boolean" },
        "bookmark_gap_detected": { "type": "boolean" },
        "gap_count": { "type": ["integer", "null"], "minimum": 0 },
        "permission_denied_since": { "type": ["string", "null"], "format": "date-time" },
        "recovered_at": { "type": ["string", "null"], "format": "date-time" },
        "transition_state": { "type": ["string", "null"], "enum": ["unknown", "healthy", "degraded", "recovering", "recovered", null] },
        "transitioned_at": { "type": ["string", "null"], "format": "date-time" },
        "dropped_events": { "type": ["integer", "null"], "minimum": 0 },
        "poison_events": { "type": ["integer", "null"], "minimum": 0 },
        "config_hash": { "type": ["string", "null"], "maxLength": 128 },
        "source_version": { "type": ["string", "null"], "maxLength": 128 },
        "prerequisite_statuses": { "$ref": "#/$defs/portable_evidence_statuses" },
        "event_family_statuses": { "$ref": "#/$defs/portable_evidence_statuses" },
        "details": { "type": "object", "additionalProperties": { "type": "string" } }
      },
      "allOf": [
        {
          "if": { "not": { "required": ["source_kind"] } },
          "then": { "required": ["channel"] }
        },
        {
          "if": { "required": ["platform"] },
          "then": { "required": ["source_kind"] }
        },
        {
          "if": { "properties": { "source_kind": { "const": "windows_event_log" } }, "required": ["source_kind"] },
          "then": { "required": ["platform", "channel"], "properties": { "platform": { "const": "windows" } } }
        },
        {
          "if": { "properties": { "source_kind": { "enum": ["linux_journal", "linux_audit", "inventory_diff", "agent_health"] } }, "required": ["source_kind"] },
          "then": {
            "required": ["platform", "source_namespace", "applicability"],
            "properties": {
              "last_event_time": { "oneOf": [{ "$ref": "event-envelope.schema.json#/$defs/required_timestamp" }, { "type": "null" }] },
              "details": { "$ref": "#/$defs/portable_details" }
            },
            "not": { "anyOf": [{ "required": ["channel"] }, { "required": ["last_record_id"] }, { "required": ["oldest_record_id"] }, { "required": ["newest_record_id"] }] }
          }
        },
        {
          "if": { "properties": { "source_kind": { "enum": ["linux_journal", "linux_audit"] } }, "required": ["source_kind"] },
          "then": { "properties": { "platform": { "const": "linux" } } }
        },
        {
          "if": { "properties": { "applicability": { "const": "applicable" } }, "required": ["applicability"] },
          "then": { "required": ["collected_checkpoint", "acknowledged_checkpoint"] }
        },
        {
          "if": { "properties": { "applicability": { "enum": ["not_applicable", "unknown", "unsupported"] } }, "required": ["applicability"] },
          "then": { "required": ["applicability_reason"] }
        },
        {
          "if": {
            "properties": { "status": { "const": "not_applicable" } },
            "required": ["source_kind", "status"]
          },
          "then": { "properties": { "applicability": { "const": "not_applicable" } } }
        },
        {
          "if": {
            "properties": { "applicability": { "const": "not_applicable" } },
            "required": ["source_kind", "applicability"]
          },
          "then": { "properties": { "status": { "const": "not_applicable" } } }
        },
        {
          "if": {
            "properties": { "status": { "const": "unsupported" } },
            "required": ["source_kind", "status"]
          },
          "then": { "properties": { "applicability": { "const": "unsupported" } } }
        },
        {
          "if": {
            "properties": { "applicability": { "const": "unsupported" } },
            "required": ["source_kind", "applicability"]
          },
          "then": { "properties": { "status": { "const": "unsupported" } } }
        }
      ]
    },
    "queue_metrics": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "queue_depth": { "type": "integer", "minimum": 0 },
        "poison_depth": { "type": "integer", "minimum": 0 },
        "oldest_queued_age_seconds": { "type": ["integer", "null"], "minimum": 0 },
        "queue_size_bytes": { "type": ["integer", "null"], "minimum": 0 },
        "max_size_bytes": { "type": ["integer", "null"], "minimum": 1 },
        "used_percent": { "type": ["number", "null"], "minimum": 0, "maximum": 1000 },
        "pressure_state": { "type": ["string", "null"], "enum": ["unknown", "normal", "warning", "high", "critical", "full", "throttled", null] },
        "send_state": { "type": ["string", "null"], "enum": ["unknown", "idle", "sending", "succeeded", "backing_off", "failed", "recovering", null] },
        "backoff_seconds": { "type": ["integer", "null"], "minimum": 0, "maximum": 86400 },
        "last_attempt_time": { "type": ["string", "null"], "format": "date-time" },
        "last_failed_send_time": { "type": ["string", "null"], "format": "date-time" },
        "last_successful_send_time": { "type": ["string", "null"], "format": "date-time" },
        "last_recovery_time": { "type": ["string", "null"], "format": "date-time" },
        "poison_events_total": { "type": ["integer", "null"], "minimum": 0 },
        "dropped_events_total": { "type": ["integer", "null"], "minimum": 0 },
        "max_size_mb": { "type": "integer", "minimum": 1 },
        "warning_size_percent": { "type": "integer", "minimum": 1, "maximum": 100 }
      }
    },
    "resource_metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["observed_at", "status"],
      "properties": {
        "observed_at": { "$ref": "event-envelope.schema.json#/$defs/required_timestamp" },
        "cpu_percent": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
        "rss_bytes": { "type": ["integer", "null"], "minimum": 0 },
        "managed_memory_bytes": { "type": ["integer", "null"], "minimum": 0 },
        "status": { "type": "string", "enum": ["observed", "partial", "unknown"] }
      }
    },
    "tamper_checks": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "binary_hash": { "type": ["string", "null"] },
        "config_hash": { "type": ["string", "null"] },
        "signature_status": { "type": ["string", "null"] },
        "acl_status": { "type": ["string", "null"] }
      }
    },
    "linux_tamper_checks": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "binary_hash": { "type": ["string", "null"], "maxLength": 128 },
        "config_hash": { "type": ["string", "null"], "maxLength": 128 },
        "signature_status": { "type": ["string", "null"], "maxLength": 128 },
        "acl_status": { "type": ["string", "null"], "maxLength": 128 }
      }
    },
    "portable_details": {
      "type": "object",
      "maxProperties": 32,
      "propertyNames": { "minLength": 1, "maxLength": 128 },
      "additionalProperties": { "type": "string", "maxLength": 1000 }
    },
    "portable_evidence_statuses": {
      "type": "object",
      "maxProperties": 32,
      "propertyNames": { "minLength": 1, "maxLength": 128 },
      "additionalProperties": { "$ref": "#/$defs/evidence_status" }
    }
  }
}
