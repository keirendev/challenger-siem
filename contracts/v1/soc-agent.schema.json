{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://challenger-siem.local/contracts/v1/soc-agent.schema.json",
  "title": "Challenger SIEM soc-agent Ask v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["question"],
  "properties": {
    "question": { "type": "string", "minLength": 1, "maxLength": 4000 },
    "context_agent_id": { "type": ["string", "null"], "maxLength": 128 },
    "context_event_id": { "type": ["string", "null"], "format": "uuid" },
    "model": { "type": ["string", "null"], "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$" },
    "reasoning_effort": { "type": ["string", "null"], "enum": [null, "none", "minimal", "low", "medium", "high", "xhigh", "max"] }
  }
}
