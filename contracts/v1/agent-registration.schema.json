{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://challenger-siem.local/contracts/v1/agent-registration.schema.json",
  "title": "Challenger SIEM Agent Registration v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["agent_id", "hostname", "os_version", "agent_version"],
  "properties": {
    "agent_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "hostname": {
      "type": "string",
      "minLength": 1,
      "maxLength": 255
    },
    "machine_guid": {
      "type": ["string", "null"],
      "maxLength": 255
    },
    "os_version": {
      "type": "string",
      "minLength": 1,
      "maxLength": 255
    },
    "agent_version": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64
    }
  }
}
