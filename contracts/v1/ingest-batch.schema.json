{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://challenger-siem.local/contracts/v1/ingest-batch.schema.json",
  "title": "Challenger SIEM Ingest Batch v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["agent_id", "batch_id", "sent_at", "events"],
  "properties": {
    "agent_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "batch_id": {
      "type": "string",
      "format": "uuid"
    },
    "sent_at": {
      "type": "string",
      "format": "date-time"
    },
    "events": {
      "type": "array",
      "minItems": 1,
      "maxItems": 500,
      "items": {
        "$ref": "./event-envelope.schema.json"
      }
    }
  }
}
