{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://challenger-siem.local/contracts/v1/telemetry-coverage.schema.json",
  "title": "Challenger SIEM Telemetry Coverage Response v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["generated_at", "lookback_start", "lookback_end", "lookback_hours", "target_level", "agents"],
  "properties": {
    "generated_at": { "type": "string", "format": "date-time" },
    "lookback_start": { "type": "string", "format": "date-time" },
    "lookback_end": { "type": "string", "format": "date-time" },
    "lookback_hours": { "type": "integer", "minimum": 1, "maximum": 168 },
    "target_level": { "$ref": "#/$defs/coverage_level" },
    "agents": { "type": "array", "items": { "$ref": "#/$defs/agent_coverage" } }
  },
  "$defs": {
    "coverage_level": { "type": "string", "enum": ["L0", "L1", "L2", "L3", "L4"] },
    "source_status": { "type": "string", "enum": ["healthy", "missing", "disabled", "stale", "degraded", "permission_denied", "unsupported", "error", "not_applicable", "excepted"] },
    "applicability": { "type": "string", "enum": ["applicable", "not_applicable", "unknown", "unsupported"] },
    "requirement": { "type": "string", "enum": ["mandatory", "optional", "role_specific"] },
    "evidence_statuses": {
      "type": "object",
      "maxProperties": 32,
      "propertyNames": { "minLength": 1, "maxLength": 128 },
      "additionalProperties": { "type": "string", "enum": ["satisfied", "observed", "not_observed", "missing", "disabled", "stale", "degraded", "permission_denied", "unsupported", "not_applicable", "excepted", "unknown"] }
    },
    "detection_prerequisite_status": { "type": "string", "enum": ["satisfied", "partially_satisfied", "missing_prerequisites", "unknown", "excepted"] },
    "string_counts": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } },
    "queue_metrics": { "$ref": "heartbeat.schema.json#/$defs/queue_metrics" },
    "resource_metrics": { "$ref": "heartbeat.schema.json#/$defs/resource_metrics" },
    "host_timezone": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "maxLength": 128 },
        "display_name": { "type": "string", "maxLength": 255 },
        "standard_name": { "type": ["string", "null"], "maxLength": 255 },
        "daylight_name": { "type": ["string", "null"], "maxLength": 255 },
        "base_utc_offset_minutes": { "type": ["integer", "null"], "minimum": -840, "maximum": 840 },
        "utc_offset_minutes": { "type": ["integer", "null"], "minimum": -840, "maximum": 840 },
        "is_daylight_saving_time": { "type": ["boolean", "null"] }
      }
    },
    "agent_coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "agent_id",
        "hostname",
        "agent_status",
        "target_level",
        "current_level",
        "overall_status",
        "recent_event_count",
        "expected_source_count",
        "reported_source_count",
        "source_status_counts",
        "missing_mandatory_sources",
        "stale_sources",
        "error_sources",
        "new_alert_count",
        "alert_status_counts",
        "active_graph_count",
        "sources",
        "inventory",
        "detection_prerequisites",
        "gaps"
      ],
      "properties": {
        "agent_id": { "type": "string", "minLength": 1, "maxLength": 128 },
        "hostname": { "type": "string", "minLength": 1, "maxLength": 255 },
        "agent_status": { "type": "string" },
        "last_seen": { "type": ["string", "null"], "format": "date-time" },
        "host_timezone": { "$ref": "#/$defs/host_timezone" },
        "platform": { "$ref": "event-envelope.schema.json#/$defs/platform" },
        "target_level": { "$ref": "#/$defs/coverage_level" },
        "current_level": { "$ref": "#/$defs/coverage_level" },
        "overall_status": { "$ref": "#/$defs/source_status" },
        "recent_event_count": { "type": "integer", "minimum": 0 },
        "expected_source_count": { "type": "integer", "minimum": 0 },
        "reported_source_count": { "type": "integer", "minimum": 0 },
        "source_status_counts": { "$ref": "#/$defs/string_counts" },
        "queue_metrics": { "oneOf": [{ "$ref": "#/$defs/queue_metrics" }, { "type": "null" }] },
        "resource_metrics": { "oneOf": [{ "$ref": "#/$defs/resource_metrics" }, { "type": "null" }] },
        "missing_mandatory_sources": { "type": "integer", "minimum": 0 },
        "stale_sources": { "type": "integer", "minimum": 0 },
        "error_sources": { "type": "integer", "minimum": 0 },
        "degraded_sources": { "type": "integer", "minimum": 0 },
        "permission_denied_sources": { "type": "integer", "minimum": 0 },
        "unsupported_sources": { "type": "integer", "minimum": 0 },
        "excepted_sources": { "type": "integer", "minimum": 0 },
        "not_applicable_sources": { "type": "integer", "minimum": 0 },
        "new_alert_count": { "type": "integer", "minimum": 0 },
        "alert_status_counts": { "$ref": "#/$defs/string_counts" },
        "active_graph_count": { "type": "integer", "minimum": 0 },
        "sources": { "type": "array", "items": { "$ref": "#/$defs/source_coverage" } },
        "inventory": { "type": "array", "items": { "$ref": "#/$defs/inventory_status" } },
        "detection_prerequisites": { "type": "array", "items": { "$ref": "#/$defs/detection_prerequisite" } },
        "gaps": { "type": "array", "items": { "type": "string" } }
      }
    },
    "source_coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_id", "display_name", "channel", "coverage_level", "required", "enabled", "reported", "status", "recent_event_count", "reason", "event_search_url", "source_health_url"],
      "properties": {
        "source_id": { "type": "string" },
        "display_name": { "type": "string" },
        "channel": { "type": "string" },
        "platform": { "$ref": "event-envelope.schema.json#/$defs/platform" },
        "source_kind": { "type": "string", "enum": ["windows_event_log", "linux_journal", "linux_audit", "inventory_diff", "agent_health"] },
        "source_namespace": { "type": "string", "minLength": 1, "maxLength": 128 },
        "applicability": { "$ref": "#/$defs/applicability" },
        "applicability_reason": { "type": "string", "minLength": 1, "maxLength": 512 },
        "requirement": { "$ref": "#/$defs/requirement" },
        "applicable_roles": { "type": "array", "maxItems": 32, "items": { "type": "string", "minLength": 1, "maxLength": 128 } },
        "prerequisite_statuses": { "$ref": "#/$defs/evidence_statuses" },
        "event_family_statuses": { "$ref": "#/$defs/evidence_statuses" },
        "coverage_level": { "$ref": "#/$defs/coverage_level" },
        "required": { "type": "boolean" },
        "enabled": { "type": "boolean" },
        "reported": { "type": "boolean" },
        "status": { "$ref": "#/$defs/source_status" },
        "last_event_time": { "type": ["string", "null"], "format": "date-time" },
        "observed_at": { "type": ["string", "null"], "format": "date-time" },
        "host_timezone": { "$ref": "#/$defs/host_timezone" },
        "lag_seconds": { "type": ["integer", "null"], "minimum": 0 },
        "collected_checkpoint": { "oneOf": [{ "$ref": "event-envelope.schema.json#/$defs/source_checkpoint" }, { "type": "null" }] },
        "acknowledged_checkpoint": { "oneOf": [{ "$ref": "event-envelope.schema.json#/$defs/source_checkpoint" }, { "type": "null" }] },
        "permission_denied_since": { "type": ["string", "null"], "format": "date-time" },
        "recovered_at": { "type": ["string", "null"], "format": "date-time" },
        "silence_seconds": { "type": ["integer", "null"], "minimum": 0 },
        "event_rate_per_minute": { "type": ["number", "null"], "minimum": 0, "maximum": 1000000 },
        "gap_count": { "type": ["integer", "null"], "minimum": 0 },
        "transition_state": { "type": ["string", "null"], "enum": ["unknown", "healthy", "degraded", "recovering", "recovered", null] },
        "transitioned_at": { "type": ["string", "null"], "format": "date-time" },
        "dropped_events": { "type": ["integer", "null"], "minimum": 0 },
        "poison_events": { "type": ["integer", "null"], "minimum": 0 },
        "source_version": { "type": ["string", "null"], "maxLength": 128 },
        "config_hash": { "type": ["string", "null"], "maxLength": 128 },
        "details": { "type": "object", "additionalProperties": { "type": "string" } },
        "recent_event_count": { "type": "integer", "minimum": 0 },
        "reason": { "type": "string" },
        "event_search_url": { "type": "string" },
        "source_health_url": { "type": "string" }
      }
    },
    "inventory_status": {
      "type": "object",
      "additionalProperties": false,
      "required": ["snapshot_type", "status", "item_count", "reason", "url"],
      "properties": {
        "snapshot_type": { "type": "string" },
        "status": { "$ref": "#/$defs/source_status" },
        "latest_collected_at": { "type": ["string", "null"], "format": "date-time" },
        "host_timezone": { "$ref": "#/$defs/host_timezone" },
        "item_count": { "type": "integer", "minimum": 0 },
        "reason": { "type": "string" },
        "url": { "type": "string" }
      }
    },
    "detection_prerequisite": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rule_id", "name", "severity", "enabled", "status", "required_sources", "healthy_sources", "missing_sources", "stale_sources", "recent_event_sources", "required_fields", "required_event_ids", "required_event_categories", "required_event_actions", "audit_policy_requirements", "inventory_requirements", "optional_sources", "reason"],
      "properties": {
        "rule_id": { "type": "string" },
        "name": { "type": "string" },
        "severity": { "type": "string", "enum": ["informational", "low", "medium", "high", "critical"] },
        "enabled": { "type": "boolean" },
        "status": { "$ref": "#/$defs/detection_prerequisite_status" },
        "required_sources": { "type": "array", "items": { "type": "string" } },
        "healthy_sources": { "type": "array", "items": { "type": "string" } },
        "missing_sources": { "type": "array", "items": { "type": "string" } },
        "stale_sources": { "type": "array", "items": { "type": "string" } },
        "recent_event_sources": { "type": "array", "items": { "type": "string" } },
        "required_fields": { "type": "array", "items": { "type": "string" } },
        "required_event_ids": { "type": "array", "items": { "type": "integer", "minimum": 0 } },
        "required_event_categories": { "type": "array", "items": { "type": "string" } },
        "required_event_actions": { "type": "array", "items": { "type": "string" } },
        "audit_policy_requirements": { "type": "array", "items": { "type": "string" } },
        "inventory_requirements": { "type": "array", "items": { "type": "string" } },
        "optional_sources": { "type": "array", "items": { "type": "string" } },
        "reason": { "type": "string" }
      }
    }
  }
}
